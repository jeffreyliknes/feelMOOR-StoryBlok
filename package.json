{
  "name": "feelmoor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tinacms dev -c \"astro dev\"",
    "build": "if [ \"$VERCEL_ENV\" = \"preview\" ]; then tinacms build --skip-cloud-checks; else tinacms build || { sleep 30; tinacms build; } || { sleep 60; tinacms build; }; fi && astro build",
    "preview": "astro preview",
    "optimize-images": "node scripts/optimize-images.mjs --replace",
    "update-image-references": "node scripts/update-image-references.mjs"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.3",
    "astro": "^5.7.2",
    "tailwindcss": "^3.4.17",
    "tinacms": "^3.9.3"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.5.1",
    "sharp": "^0.34.5"
  }
}
