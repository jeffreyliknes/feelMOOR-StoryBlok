        {
          "title": "Alpsee Coaster",
          "description": "Deutschlands längste Ganzjahres-Rodelbahn, ist im Winter unabhängig von der Schneelage in Betrieb. Über 2,8 km lang, bis zu 40 km/h schnell und über 100 Kurven, Wellen + Jumps. Dank Schienenführung ist Umkippen ausgeschlossen",
          "location": "Immenstadt am Alpsee",
          "distance_km": 65.0,
          "distance_note": "(Entfernung ca. 65 km )",
          "features": [],
          "external_url": "https://www.alpsee-bergwelt.de/spass/alpsee-coaster.html"
        },
        {
          "title": "allgäu skyline park",
          "description": "Bayerns größter Freizeitpark mit mehr als 60 Fahrgeschäften & Attraktionen wartet auf dich. Neben Achterbahnen, Wildwasserrutschen und Kinderkarussells findet du jede Menge gastronomischer Angebote, eingebettet in einem attraktiven Außengelände in Mitten des Allgäus.",
          "location": "Bad Wörishofen",
          "distance_km": 68.0,
          "distance_note": "(Entfernung ca. 68 km )",
          "features": [],
          "external_url": "https://www.skylinepark.de/"
