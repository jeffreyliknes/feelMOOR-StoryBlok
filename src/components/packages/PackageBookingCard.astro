---
interface BookingOption {
  label: string;
  href: string;
}

interface Props {
  nights?: string;
  priceFrom?: number;
  priceLabel?: string;
  includes?: string[];
  bookingOptions?: BookingOption[];
  bookingLink?: string;
}

const {
  nights,
  priceFrom,
  priceLabel,
  includes = [],
  bookingOptions = [],
  bookingLink,
} = Astro.props;
---

<div class="rounded-xl bg-white border border-stone-light shadow-md p-7 lg:sticky lg:top-[calc(var(--header-h)+2rem)]">
  <p class="caption-label mb-3">Ihr Angebot</p>

  {priceFrom && (
    <div class="mb-5">
      <p class="font-display font-light text-ink-dark text-3xl">ab {priceFrom} €</p>
      {priceLabel && (
        <p class="text-xs text-ink-muted mt-1">{priceLabel}</p>
      )}
    </div>
  )}

  {nights && (
    <p class="text-xs text-ink-muted mb-5 border-b border-stone-light pb-4">{nights}</p>
  )}

  {includes && includes.length > 0 && (
    <div class="mb-6">
      <p class="text-xs tracking-caption uppercase text-gold font-medium mb-3">Leistungen</p>
      <ul class="space-y-2">
        {includes.slice(0, 5).map((item) => (
          <li class="flex items-start gap-2 text-xs text-ink-muted">
            <span class="w-1 h-1 rounded-full bg-gold mt-2 flex-shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  )}

  <div class="space-y-3 pt-4 border-t border-stone-light">
    {bookingOptions && bookingOptions.length > 0 ? (
      bookingOptions.map((opt) => (
        <a href={opt.href} target="_blank" rel="noopener" class="btn-gold w-full justify-between">
          <span class="font-sans text-[0.7rem] uppercase tracking-wider opacity-75">{opt.label}</span>
          <span class="text-xs">Verfügbarkeit prüfen</span>
        </a>
      ))
    ) : bookingLink ? (
      <a href={bookingLink} class="btn-gold w-full justify-center">Jetzt buchen</a>
    ) : (
      <a href="#booking" class="btn-gold w-full justify-center">Verfügbarkeit prüfen</a>
    )}
    <a href="/service-kontakt" class="btn-outline-gold w-full justify-center">Persönliche Anfrage</a>
  </div>
</div>
