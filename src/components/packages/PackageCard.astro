---
interface Props {
  pkg: { slug: string; data: Record<string, any> };
  /** "panel" = bordered card with button (Angebote index); "overlay" = image-overlay card (homepage) */
  variant?: 'panel' | 'overlay';
  /** Image to use when the package has none (overlay variant only) */
  fallbackImage?: string;
}

const { pkg, variant = 'panel', fallbackImage = '/images/hotel/15-a-0015-IRZ_9788-ingorack.com.webp' } = Astro.props;
const data = pkg.data;
const detailHref = `/angebote/${pkg.slug}`;
---

{variant === 'overlay' ? (
  <article class="group card-hover">
    <a href={data.booking_link ?? detailHref} class="block">
      <div class="relative aspect-[4/3] overflow-hidden">
        <img
          src={data.image ?? fallbackImage}
          alt={data.image_alt ?? data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-ink-dark/30"></div>
        {data.tag && (
          <div class="absolute top-4 left-4 z-20">
            <span class="caption-label bg-cream/90 px-2.5 py-1">{data.tag}</span>
          </div>
        )}
      </div>
      <div class="bg-white px-6 pt-6 pb-7 border border-stone-light border-t-0 group-hover:border-gold/30 transition-colors duration-300">
        <div class="flex items-start justify-between gap-3 mb-3">
          <h3 class="font-display font-light text-[1.4rem] text-ink-dark leading-tight">
            {data.title}
          </h3>
          {data.nights && (
            <span class="text-xs text-ink-muted bg-stone-light/60 px-2.5 py-1 flex-shrink-0 mt-1">
              {data.nights}
            </span>
          )}
        </div>
        {data.teaser && (
          <p class="text-xs text-ink-muted leading-relaxed mb-5">{data.teaser}</p>
        )}
        <span class="inline-flex items-center gap-2 text-xs tracking-wider uppercase text-gold font-medium group-hover:gap-3 transition-all duration-200">
          Mehr erfahren
          <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none">
            <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </a>
  </article>
) : (
  <article class="group bg-white border border-stone-light rounded-xl overflow-hidden hover:border-gold/30 transition-colors duration-300 flex flex-col">
    <div class="relative overflow-hidden bg-stone-light/50 aspect-[4/3]">
      {data.image ? (
        <img
          src={data.image}
          alt={data.image_alt ?? data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-stone-light to-stone-light/70 flex items-center justify-center">
          <svg class="w-12 h-12 text-stone/30" viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
        </div>
      )}
    </div>

    <div class="p-6 lg:p-7 flex flex-col flex-grow">
      {data.tag && (
        <p class="caption-label mb-2 text-gold">{data.tag}</p>
      )}
      <h3 class="font-display font-light text-ink-dark text-xl lg:text-2xl leading-tight mb-3">
        {data.title}
      </h3>

      {data.nights && (
        <p class="text-xs text-ink-muted mb-3 pb-3 border-b border-stone-light/60">
          {data.nights}
        </p>
      )}

      {data.teaser && (
        <p class="text-xs text-ink-muted leading-relaxed mb-5 flex-grow">
          {data.teaser}
        </p>
      )}

      {data.price_from && (
        <div class="mb-5">
          <p class="font-display font-light text-ink-dark text-2xl">ab {data.price_from} €</p>
          {data.price_label && (
            <p class="text-xs text-ink-muted mt-1">{data.price_label}</p>
          )}
        </div>
      )}

      <div class="flex gap-3 pt-4 border-t border-stone-light/60 mt-auto">
        <a href={detailHref} class="btn-gold flex-1 justify-center text-center">
          Mehr erfahren
          <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none">
            <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </article>
)}
