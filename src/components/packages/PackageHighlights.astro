---
interface Highlight {
  title: string;
  text?: string;
}

interface Props {
  highlights: Highlight[];
  heading?: string;
}

const { highlights, heading } = Astro.props;
---

{highlights && highlights.length > 0 && (
  <section class="py-12 lg:py-16 bg-forest text-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      {heading && (
        <h2 class="font-display font-light text-2xl lg:text-3xl mb-8">{heading}</h2>
      )}
      <div class="grid gap-px bg-cream/15 rounded-xl overflow-hidden sm:grid-cols-2 lg:grid-cols-4">
        {highlights.map((item) => (
          <div class="bg-forest p-7">
            <p class="font-display font-light text-xl text-cream mb-2">{item.title}</p>
            {item.text && (
              <p class="text-xs text-cream/70 leading-relaxed">{item.text}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}
