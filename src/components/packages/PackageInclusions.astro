---
interface Props {
  items: string[];
  note?: string;
  heading?: string;
}

const { items, note, heading = 'Inklusiv-Leistungen' } = Astro.props;
---

{items && items.length > 0 && (
  <div>
    <h2 class="font-display font-light text-ink-dark text-2xl mb-5">{heading}</h2>
    <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-3">
      {items.map((item) => (
        <li class="flex items-start gap-3 text-xs text-ink-muted leading-relaxed">
          <span class="w-1.5 h-1.5 rounded-full bg-gold mt-1.5 flex-shrink-0"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
    {note && (
      <p class="text-xs text-ink-muted/80 leading-relaxed mt-5 pt-4 border-t border-stone-light/60">{note}</p>
    )}
  </div>
)}
