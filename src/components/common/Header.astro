---
import { getCollection } from 'astro:content';
import site from '@/content/settings/site.json';
import {
  buildSiteNavigation,
  type HeaderNavExtra,
} from '@/lib/header-nav';

const packages = await getCollection('packages');
const rooms = await getCollection('rooms');

const navExtras =
  (site as typeof site & { header_nav_links?: HeaderNavExtra[] })
    .header_nav_links ?? [];

const nav = buildSiteNavigation(packages, rooms, navExtras);

interface Props {
  locale?: 'de' | 'en';
}

const { locale = 'de' } = Astro.props;
const homeHref = locale === 'en' ? '/en' : '/';
const isEn = locale === 'en';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 bg-cream/95 transition-all duration-300"
  style="height: var(--header-h);"
>
  <div class="max-w-screen-xl mx-auto px-6 h-full flex items-center justify-between gap-6">

    <!-- Logo (~20% larger than prior h-12 / lg:h-14 for clearer presence in nav) -->
    <a href={homeHref} class="flex-shrink-0 flex items-center group" aria-label={isEn ? 'feelMOOR home' : 'feelMOOR Startseite'}>
      <img
        src="/images/Logos/logo-feelmoor-horizontal.svg"
        alt="feelMOOR Therme Bad Wurzach"
        width="444"
        height="164"
        class="h-[3.6rem] w-auto object-contain lg:h-[4.2rem]"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label={isEn ? 'Main navigation' : 'Hauptnavigation'}>
      {nav.map((item) => (
        <div class="nav-item relative" data-nav-id={item.id}>
          <button
            class="nav-trigger flex items-center gap-1 px-3.5 py-2 text-[11.5px] font-medium tracking-wide uppercase text-ink-muted hover:text-gold transition-colors duration-200"
            aria-expanded="false"
            aria-haspopup="true"
          >
            {item.label}
            <svg class="nav-chevron w-3 h-3 transition-transform duration-200" viewBox="0 0 12 12" fill="none">
              <path d="M2 4.5L6 8.5L10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      ))}
    </nav>

    <!-- Right: Language + Book -->
    <div class="hidden lg:flex items-center gap-4 flex-shrink-0">
      <div class="flex items-center gap-1.5 text-[10.5px] tracking-wide font-medium">
        <a href="/" class:list={[isEn ? 'text-ink-muted hover:text-gold' : 'text-gold', 'uppercase transition-colors']}>DE</a>
        <span class="text-stone">·</span>
        <a href="/en" class:list={[isEn ? 'text-gold' : 'text-ink-muted hover:text-gold', 'uppercase transition-colors']}>EN</a>
      </div>
      <a href="/service-kontakt" class="text-[10.5px] tracking-wider uppercase text-ink-muted hover:text-gold transition-colors">
        Kontakt
      </a>
      <a href="#booking" class="btn-gold text-[10px] py-3 px-6">
        Jetzt buchen
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden flex flex-col gap-1.5 p-2"
      aria-label={isEn ? 'Open menu' : 'Menü öffnen'}
      aria-expanded="false"
    >
      <span class="hamburger-line block w-6 h-px bg-ink-dark transition-all duration-300"></span>
      <span class="hamburger-line block w-4 h-px bg-ink-dark transition-all duration-300 ml-auto"></span>
      <span class="hamburger-line block w-6 h-px bg-ink-dark transition-all duration-300"></span>
    </button>
  </div>

  <!-- Gold accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-stone-light"></div>
</header>

<!-- ── Mega menu panels (rendered outside header flow) ── -->
{nav.map((item) => (
  <div
    id={`panel-${item.id}`}
    class="mega-panel z-30"
    role="region"
    aria-label={item.label}
  >
    <div class="max-w-screen-xl mx-auto px-6 py-10 grid gap-8"
         style={`grid-template-columns: repeat(${item.columns.length}, 1fr) 280px`}>

      <!-- Link columns -->
      {item.columns.map((col) => (
        <div>
          <p class="caption-label mb-4">{col.heading}</p>
          <ul class="space-y-1">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="block py-1.5 text-[13px] text-ink-muted hover:text-gold transition-colors duration-150 hover:translate-x-1 transform transition-transform"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Featured card -->
      <div class="border-l border-stone-light pl-8 flex flex-col justify-between">
        <div>
          <p class="caption-label mb-3">{item.featured.tag}</p>
          <h3 class="font-display font-light text-[1.55rem] text-ink-dark leading-tight mb-3">
            {item.featured.heading}
          </h3>
          <p class="text-[12.5px] text-ink-muted leading-relaxed">
            {item.featured.body}
          </p>
        </div>
        <a href={item.featured.cta.href} class="btn-outline-gold mt-6 self-start text-[10px] py-2.5 px-5">
          {item.featured.cta.label}
          <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none">
            <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="border-t border-stone-light bg-stone-light/30 px-6 py-3">
      <div class="max-w-screen-xl mx-auto flex items-center gap-6">
        <a href={item.href} class="text-[10.5px] tracking-caption uppercase text-gold hover:text-gold-600 transition-colors">
          Alle {item.label} →
        </a>
        <span class="text-stone text-xs">·</span>
        <a href="/gutscheine" class="text-[10.5px] tracking-wide text-ink-muted hover:text-gold transition-colors">Gutscheine</a>
        <a href="/service-kontakt" class="text-[10.5px] tracking-wide text-ink-muted hover:text-gold transition-colors">Kontakt</a>
      </div>
    </div>
  </div>
))}

<!-- ── Mobile nav overlay ── -->
<div
  id="mobile-nav"
  class="fixed inset-0 z-50 bg-cream flex flex-col translate-x-full transition-transform duration-400 ease-in-out lg:hidden"
  style="top: var(--header-h);"
>
  <div class="overflow-y-auto flex-1 px-6 py-8">
    {nav.map((item) => (
      <div class="mobile-accordion border-b border-stone-light">
        <button class="mobile-accordion-trigger w-full flex items-center justify-between py-4 text-left">
          <span class="font-body text-[13px] font-medium tracking-wide uppercase text-ink-dark">
            {item.label}
          </span>
          <svg class="mobile-chevron w-4 h-4 text-gold transition-transform duration-200" viewBox="0 0 12 12" fill="none">
            <path d="M2 4.5L6 8.5L10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="mobile-accordion-content hidden pb-4 pl-2">
          {item.columns.map((col) => (
            <div class="mb-4">
              <p class="caption-label mb-2">{col.heading}</p>
              <ul class="space-y-1">
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="block py-1 text-[13px] text-ink-muted hover:text-gold transition-colors">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    ))}
    <div class="flex items-center gap-2 pb-4 mb-2 border-b border-stone-light">
      <a href="/" class:list={[isEn ? 'text-ink-muted' : 'text-gold', 'text-[10.5px] tracking-wide font-medium uppercase hover:text-gold transition-colors']}>DE</a>
      <span class="text-stone text-xs">·</span>
      <a href="/en" class:list={[isEn ? 'text-gold' : 'text-ink-muted', 'text-[10.5px] tracking-wide font-medium uppercase hover:text-gold transition-colors']}>EN</a>
    </div>
    <div class="pt-2 flex flex-col gap-3">
      <a href="#booking" class="btn-gold text-center justify-center">Jetzt buchen</a>
      <a href="/gutscheine" class="btn-outline-gold text-center justify-center">Gutscheine</a>
    </div>
  </div>
</div>

<!-- Overlay backdrop -->
<div id="nav-backdrop" class="fixed inset-0 z-20 bg-ink/20 backdrop-blur-sm hidden lg:hidden"></div>

<script>
  // ── Desktop mega menu ──
  const header    = document.getElementById('site-header')!;
  const panels    = document.querySelectorAll<HTMLElement>('.mega-panel');
  const navItems  = document.querySelectorAll<HTMLElement>('.nav-item');
  let   closeTimer: ReturnType<typeof setTimeout>;

  function openPanel(id: string) {
    clearTimeout(closeTimer);
    panels.forEach(p => p.classList.remove('is-open'));
    const panel = document.getElementById(`panel-${id}`);
    if (panel) panel.classList.add('is-open');

    const trigger = document.querySelector<HTMLElement>(`[data-nav-id="${id}"] .nav-trigger`);
    if (trigger) {
      trigger.setAttribute('aria-expanded', 'true');
      trigger.querySelector<SVGElement>('.nav-chevron')?.classList.add('rotate-180');
    }
  }

  function closeAll() {
    closeTimer = setTimeout(() => {
      panels.forEach(p => p.classList.remove('is-open'));
      document.querySelectorAll<HTMLElement>('.nav-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
        t.querySelector<SVGElement>('.nav-chevron')?.classList.remove('rotate-180');
      });
    }, 120);
  }

  navItems.forEach(item => {
    const id = item.dataset.navId!;
    item.addEventListener('mouseenter', () => openPanel(id));
    item.addEventListener('mouseleave', closeAll);
  });

  panels.forEach(panel => {
    panel.addEventListener('mouseenter', () => clearTimeout(closeTimer));
    panel.addEventListener('mouseleave', closeAll);
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.nav-item') && !(e.target as Element).closest('.mega-panel')) {
      closeAll();
    }
  });

  // ── Scroll-based header style ──
  window.addEventListener('scroll', () => {
    header.classList.toggle('header-scrolled', window.scrollY > 40);
  }, { passive: true });

  // ── Mobile menu ──
  const mobileToggle  = document.getElementById('mobile-menu-toggle')!;
  const mobileNav     = document.getElementById('mobile-nav')!;
  const backdrop      = document.getElementById('nav-backdrop')!;
  const hamLines      = mobileToggle.querySelectorAll<HTMLElement>('.hamburger-line');
  let   menuOpen      = false;

  function toggleMobileMenu() {
    menuOpen = !menuOpen;
    mobileNav.classList.toggle('translate-x-full', !menuOpen);
    backdrop.classList.toggle('hidden', !menuOpen);
    mobileToggle.setAttribute('aria-expanded', String(menuOpen));

    if (menuOpen) {
      hamLines[0].style.transform = 'translateY(6px) rotate(45deg)';
      hamLines[1].style.opacity   = '0';
      hamLines[2].style.transform = 'translateY(-6px) rotate(-45deg)';
    } else {
      hamLines.forEach(l => { l.style.transform = ''; l.style.opacity = ''; });
    }
  }

  mobileToggle.addEventListener('click', toggleMobileMenu);
  backdrop.addEventListener('click', toggleMobileMenu);

  // Mobile accordion
  document.querySelectorAll<HTMLElement>('.mobile-accordion-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const content  = btn.nextElementSibling as HTMLElement;
      const chevron  = btn.querySelector<SVGElement>('.mobile-chevron');
      const isOpen   = !content.classList.contains('hidden');

      // Close others
      document.querySelectorAll<HTMLElement>('.mobile-accordion-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll<SVGElement>('.mobile-chevron').forEach(c => c.classList.remove('rotate-180'));

      if (!isOpen) {
        content.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
      }
    });
  });
</script>
