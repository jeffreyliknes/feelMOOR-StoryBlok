---
import site from '@/content/settings/site.json';

interface Props {
  locale?: 'de' | 'en';
}

const { locale = 'de' } = Astro.props;
const homeHref = locale === 'en' ? '/en' : '/';
const isEn = locale === 'en';

const year = new Date().getFullYear();
const cols = site.footer_columns;
---

<footer class="bg-forest text-cream/80">

  <!-- Main footer grid -->
  <div class="max-w-screen-xl mx-auto px-6 pt-16 pb-10">
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-12">

      <!-- Brand column -->
      <div class="col-span-2 lg:col-span-1">
        <a href={homeHref} class="inline-block mb-5">
          <img
            src="/images/Logos/logo-feelmoor-horizontal.svg"
            alt="feelMOOR Therme Bad Wurzach"
            width="444"
            height="164"
            class="h-14 w-auto object-contain"
            loading="lazy"
          />
        </a>
        <address class="not-italic text-xs leading-relaxed text-cream/60 mb-5">
          {site.address_street}<br />
          {site.address_zip_city}<br />
          {site.address_region}, {site.address_country}
        </address>
        <a href={`tel:${site.phone_link}`} class="text-xs text-gold hover:text-gold-300 transition-colors block mb-1">
          {site.phone_display}
        </a>
        <a href={`mailto:${site.email}`} class="text-xs text-gold hover:text-gold-300 transition-colors">
          {site.email}
        </a>

        <!-- Social -->
        <div class="flex gap-3 mt-6">
          <a href={site.social_instagram} aria-label="Instagram" class="w-8 h-8 border border-cream/20 flex items-center justify-center hover:border-gold/60 hover:text-gold transition-colors text-cream/50">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href={site.social_facebook} aria-label="Facebook" class="w-8 h-8 border border-cream/20 flex items-center justify-center hover:border-gold/60 hover:text-gold transition-colors text-cream/50">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {cols.map((col) => (
        <div>
          <p class="text-xs tracking-caption uppercase text-gold mb-4 font-medium">{col.heading}</p>
          <ul class="space-y-2">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-xs text-cream/60 hover:text-cream transition-colors duration-150">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Newsletter strip -->
    <div class="mt-14 border-t border-cream/10 pt-10">
      <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
          <p class="caption-label" style="color: #B39D4D;">Newsletter</p>
          <p class="font-display font-light text-cream text-xl mt-1">Bleiben Sie immer informiert</p>
        </div>
        <form class="flex gap-0 w-full max-w-md" onsubmit="return false">
          <input
            type="email"
            placeholder="Ihre E-Mail-Adresse"
            class="flex-1 bg-cream/10 border border-cream/20 px-4 py-3 text-xs text-cream placeholder:text-cream/40 focus:outline-none focus:border-gold/60 transition-colors"
          />
          <button type="submit" class="bg-gold hover:bg-gold-600 text-white px-6 py-3 text-xs tracking-wider uppercase font-medium transition-colors duration-300 flex-shrink-0">
            Anmelden
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-cream/10">
    <div class="max-w-screen-xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-cream/40">
        © {year} {site.copyright_name}
      </p>
      <div class="flex items-center gap-5">
        <a href="/impressum"   class="text-xs text-cream/40 hover:text-cream/70 transition-colors">Impressum</a>
        <a href="/datenschutz" class="text-xs text-cream/40 hover:text-cream/70 transition-colors">Datenschutz</a>
        <a href="/sitemap.xml" class="text-xs text-cream/40 hover:text-cream/70 transition-colors">Sitemap</a>
      </div>
      <div class="flex items-center gap-2">
        <a href="/"   class:list={[isEn ? 'text-cream/40 hover:text-cream/70' : 'font-medium text-cream', 'text-xs transition-colors']}>DE</a>
        <span class="text-cream/20 text-xs">·</span>
        <a href="/en" class:list={[isEn ? 'font-medium text-cream' : 'text-cream/40 hover:text-cream/70', 'text-xs transition-colors']}>EN</a>
      </div>
    </div>
  </div>
</footer>
