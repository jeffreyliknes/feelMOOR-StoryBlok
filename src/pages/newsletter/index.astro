---
import PageLayout from '@/layouts/PageLayout.astro';
import pageData from '@/content/pages/newsletter.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <!-- ── Page Hero ── -->
  <section class="relative py-24 lg:py-32 bg-forest-700 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-800 via-forest-700 to-forest-600">
      <div class="absolute inset-0 opacity-10"
           style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22/%3E%3C/svg%3E')">
      </div>
    </div>
    <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center">
      <p class="caption-label mb-4">{page.hero_caption}</p>
      <h1 class="font-display font-light text-cream" style="font-size:clamp(2.5rem,6vw,5rem);line-height:1.06;">{page.hero_heading}</h1>
      <p class="text-cream/70 text-sm max-w-xl mx-auto mt-5 leading-relaxed">{page.hero_intro}</p>
      <nav class="mt-8 flex items-center justify-center gap-2 text-xs text-cream/40">
        <a href="/" class="hover:text-cream/70 transition-colors">Start</a>
        <span>›</span>
        <span class="text-cream/60">Newsletter</span>
      </nav>
    </div>
  </section>

  <!-- ── Newsletter Content & Signup ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        {/* Left Column - Benefits */}
        <div>
          <p class="caption-label mb-4 text-gold">Informationen</p>
          <h2 class="font-display font-light text-ink-dark mb-6" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted mb-8 leading-relaxed">{page.intro_body}</p>

          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-gold mt-1 flex-shrink-0">✓</span>
              <span class="text-xs text-ink-muted">Exklusive Angebote und Frühbucher-Rabatte</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-1 flex-shrink-0">✓</span>
              <span class="text-xs text-ink-muted">Saisonale Wellness- und Paketangebote</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-1 flex-shrink-0">✓</span>
              <span class="text-xs text-ink-muted">Gesundheitstipps vom feelMOOR-Ärzteteam</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-1 flex-shrink-0">✓</span>
              <span class="text-xs text-ink-muted">News, Events und Neuigkeiten aus dem Resort</span>
            </li>
          </ul>
        </div>

        {/* Right Column - Signup Form */}
        <div class="bg-white border border-stone-light p-8 lg:p-10 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.5rem;">Newsletter abonnieren</h3>

          <form action="/service-kontakt" method="POST" class="space-y-5">
            {/* Name Field */}
            <div>
              <label for="name" class="block text-xs tracking-widest uppercase text-gold mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Ihr Name"
                required
                class="w-full px-4 py-3 border border-stone-light rounded-sm text-xs text-ink-dark placeholder-ink-muted/50 focus:outline-none focus:border-gold transition-colors"
              />
            </div>

            {/* Email Field */}
            <div>
              <label for="email" class="block text-xs tracking-widest uppercase text-gold mb-2">E-Mail-Adresse</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="info@beispiel.de"
                required
                class="w-full px-4 py-3 border border-stone-light rounded-sm text-xs text-ink-dark placeholder-ink-muted/50 focus:outline-none focus:border-gold transition-colors"
              />
            </div>

            {/* Submit Button */}
            <div class="pt-2">
              <button type="submit" class="w-full btn-gold text-center">
                Jetzt abonnieren
              </button>
            </div>
          </form>

          {/* Privacy Note */}
          <p class="text-xs text-ink-muted mt-6 pt-6 border-t border-stone-light leading-relaxed">
            {page.privacy_note}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Back to Home ── -->
  <section class="py-12 bg-stone-light/30 border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <a href="/" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
        Zurück zur Startseite
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</PageLayout>
