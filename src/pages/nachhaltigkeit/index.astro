---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import { fetchPage } from '@/lib/storyblok';
import nachhaltigkeitFallback from '@/content/pages/nachhaltigkeit.json';

const page = (await fetchPage('nachhaltigkeit')) ?? nachhaltigkeitFallback;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Nachhaltigkeit' }]}
  />

  <!-- ── Intro Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Verantwortung</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        <div class="bg-forest-700 p-8 lg:p-12 text-cream rounded-sm flex flex-col justify-center min-h-[300px] lg:min-h-[400px]">
          <p class="font-display font-light text-cream text-xl lg:text-2xl leading-snug">{page.intro_quote}</p>
          <div class="border-t border-cream/20 pt-6 mt-8">
            <p class="text-xs tracking-widest uppercase text-gold">feelMOOR goes green</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Image band ── -->
  <section class="relative h-[40vh] min-h-[280px] overflow-hidden">
    <img src="/images/allgaeu/WurzacherRied6.webp" alt="Wurzacher Ried" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-forest-700/30"></div>
  </section>

  <!-- ── Initiatives Grid ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="caption-label text-gold mb-2">Unsere Projekte</p>
        <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Konkrete Umwelt- und Naturschutzprojekte</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {page.initiatives?.map((item) => (
          <div class="bg-white border border-stone-light p-8 lg:p-10">
            <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.6rem);">{item.title}</h3>
            <p class="text-xs text-ink-muted mt-4 leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA (Modified) ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Nachhaltig Urlaub machen</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Erfahren Sie mehr über unser Engagement oder planen Sie Ihren nachhaltigen Aufenthalt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/hotel" class="btn-gold">Unser Hotel</a>
        <a href="/service-kontakt" class="btn-outline-gold">Mehr erfahren</a>
      </div>
    </div>
  </section>

</PageLayout>
