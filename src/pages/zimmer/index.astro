---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import roomsOverview from '@/content/pages/rooms-overview.json';

const roomTypes = (await getCollection('rooms')).sort(
  (a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99)
);

const page = roomsOverview;
const amenitiesList: { label: string }[] = Array.isArray(page.amenities) ? page.amenities : [];
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Zimmer & Suiten' }]}
  />

  <!-- ── Room type cards ── -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6 space-y-10">
      {roomTypes.map((room, i) => (
        <article class={`grid lg:grid-cols-2 gap-0 group ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>

          <!-- Image -->
          <div class={`relative overflow-hidden aspect-[16/10] lg:aspect-auto min-h-[340px] ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
            <img
              src={room.data.preview_image}
              alt={room.data.name + ', feelMOOR Gesundresort'}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-ink-dark/20"></div>
            {room.data.highlight && (
              <div class="absolute top-5 right-5 z-20 bg-gold text-white text-xs tracking-caption uppercase px-3 py-1.5">
                Beliebt
              </div>
            )}
          </div>

          <!-- Content -->
          <div class={`bg-white border border-stone-light group-hover:border-gold/20 transition-colors duration-300 p-8 lg:p-12 flex flex-col justify-center ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
            {room.data.tagline && (
              <p class="caption-label mb-3">{room.data.tagline}</p>
            )}
            <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.8rem,3.5vw,3rem);line-height:1.1;">
              {room.data.name}
            </h2>
            {room.data.variants && (
              <p class="text-xs text-gold tracking-wide mt-2 mb-1">{room.data.variants}</p>
            )}
            <div class="flex items-center gap-5 mt-3 mb-5">
              {room.data.size && (
                <span class="text-xs text-ink-muted border border-stone px-2.5 py-1">{room.data.size}</span>
              )}
              {room.data.capacity && (
                <span class="text-xs text-ink-muted border border-stone px-2.5 py-1">{room.data.capacity}</span>
              )}
            </div>
            {room.data.feature_groups[0] && (
              <ul class="grid grid-cols-2 gap-x-4 gap-y-2 mb-8">
                {room.data.feature_groups[0].items.map((f) => (
                  <li class="flex items-center gap-2 text-xs text-ink-muted">
                    <span class="w-1.5 h-1.5 rounded-full bg-gold flex-shrink-0"></span>
                    {f}
                  </li>
                ))}
              </ul>
            )}

            <div class="flex flex-wrap gap-3">
              <a href={`/zimmer/${room.slug}`} class="btn-gold">
                Zimmer ansehen
                <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <a href="#booking" class="btn-outline-gold">Verfügbarkeit prüfen</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>


  <!-- ── Included amenities ── -->
  <section class="py-20 bg-forest-700 relative overflow-hidden">
    <div class="absolute inset-0 bg-forest opacity-95"></div>
    <div class="relative z-10 max-w-screen-xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="caption-label mb-3">{page.amenities_subheading}</p>
        <h2 class="font-display font-light text-cream" style="font-size:clamp(1.75rem,3.5vw,3rem);"
            set:html={page.amenities_heading.replace(' inbegriffen', ' <em class="italic" style="color:#B39D4D;">inbegriffen</em>')}>
        </h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
        {amenitiesList.map((a) => (
          <div class="text-center py-6 px-4 border border-cream/10 hover:border-gold/40 transition-colors duration-300 group">
            <div class="w-10 h-10 border border-gold/40 flex items-center justify-center mx-auto mb-3 group-hover:bg-gold/10 transition-colors">
              <span class="text-gold text-lg leading-none">✦</span>
            </div>
            <p class="text-xs text-cream/70 leading-snug">{a.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ── CTA ── -->
  <section class="py-16 bg-white border-b border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">
        {page.cta_heading}
      </h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">{page.cta_body}</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>

</PageLayout>
