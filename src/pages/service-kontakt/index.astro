---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import { fetchPage, fetchSiteSettings } from '@/lib/storyblok';
import kontaktFallback from '@/content/pages/service-kontakt.json';
import siteSettingsFallback from '@/content/settings/site.json';

const page = (await fetchPage('service-kontakt')) ?? kontaktFallback;
const site = (await fetchSiteSettings()) ?? siteSettingsFallback;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Kontakt' }]}
  />

  <!-- ── Contact Information & Map ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        {/* Left Column - Contact Info */}
        <div>
          <h2 class="font-display font-light text-ink-dark mb-10" style="font-size:clamp(1.75rem,3.5vw,3rem);">Kontaktieren Sie uns</h2>

          {/* Address Card */}
          <div class="mb-10">
            <p class="text-xs tracking-widest uppercase text-gold mb-3">{page.address_label}</p>
            <p class="text-sm text-ink-dark font-medium mb-2">{site.address_street}</p>
            <p class="text-sm text-ink-dark font-medium mb-4">{site.address_zip_city}</p>
            <a href="https://maps.google.com/?q={site.address_street}+{site.address_zip_city}" target="_blank" class="text-xs text-gold font-medium hover:gap-2 transition-all inline-flex items-center gap-1">
              Auf Google Maps öffnen
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          {/* Phone */}
          <div class="mb-10 pb-10 border-b border-stone-light">
            <p class="text-xs tracking-widest uppercase text-gold mb-3">{page.phone_label}</p>
            <a href="tel:{site.phone_link}" class="text-sm text-ink-dark font-medium hover:text-gold transition-colors">{site.phone_display}</a>
          </div>

          {/* Email */}
          <div>
            <p class="text-xs tracking-widest uppercase text-gold mb-3">{page.email_label}</p>
            <a href="mailto:{site.email}" class="text-sm text-ink-dark font-medium hover:text-gold transition-colors">{site.email}</a>
          </div>
        </div>

        {/* Right Column - Map Placeholder */}
        <div>
          <div class="bg-stone-light/30 aspect-video rounded-sm flex items-center justify-center border border-stone-light">
            <div class="text-center">
              <p class="text-xs text-ink-muted mb-4">Karte wird geladen...</p>
              <a href="https://maps.google.com/?q={site.address_street}+{site.address_zip_city}" target="_blank" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
                Google Maps öffnen
                <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Directions Section ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <h2 class="font-display font-light text-ink-dark mb-12 text-center" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.directions_heading}</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {/* By Car */}
        <div class="bg-white border border-stone-light p-8 lg:p-10 rounded-sm">
          <p class="text-xs tracking-widest uppercase text-gold mb-4">Mit dem PKW</p>
          <p class="text-xs text-ink-muted leading-relaxed">{page.directions_by_car}</p>
        </div>

        {/* By Train */}
        <div class="bg-white border border-stone-light p-8 lg:p-10 rounded-sm">
          <p class="text-xs tracking-widest uppercase text-gold mb-4">Mit dem Zug</p>
          <p class="text-xs text-ink-muted leading-relaxed">{page.directions_by_train}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Reception Hours Strip ── -->
  <section class="py-12 bg-cream border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <p class="text-xs text-ink-dark font-medium">{page.opening_hours_reception}</p>
    </div>
  </section>

  <!-- ── Bottom Buttons (No Booking CTA) ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark mb-8" style="font-size:clamp(1.5rem,3vw,2.5rem);">Zurück zum Anfang</h2>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Direkt buchen</a>
        <a href="/" class="btn-outline-gold">Zur Startseite</a>
      </div>
    </div>
  </section>

</PageLayout>
