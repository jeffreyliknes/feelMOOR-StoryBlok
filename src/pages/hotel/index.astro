---
import PageLayout from '@/layouts/PageLayout.astro';
import hotelData from '@/content/pages/hotel.json';

const page = hotelData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <!-- ── Page Hero ── -->
  <section class="relative py-24 lg:py-32 bg-forest-700 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-800 via-forest-700 to-forest-600">
      <div class="absolute inset-0 opacity-10"
           style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22/%3E%3C/svg%3E')">
      </div>
    </div>
    <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center">
      <p class="caption-label mb-4">{page.hero_caption}</p>
      <h1 class="font-display font-light text-cream" style="font-size:clamp(2.5rem,6vw,5rem);line-height:1.06;">{page.hero_heading}</h1>
      <p class="text-cream/70 text-[14px] max-w-xl mx-auto mt-5 leading-relaxed">{page.hero_intro}</p>
      <nav class="mt-8 flex items-center justify-center gap-2 text-[11px] text-cream/40">
        <a href="/" class="hover:text-cream/70 transition-colors">Start</a>
        <span>›</span>
        <span class="text-cream/60">Hotel & Resort</span>
      </nav>
    </div>
  </section>

  <!-- ── Intro Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Willkommen</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-[13.5px] text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        <div class="bg-forest-700 p-8 lg:p-12 text-cream rounded-sm flex flex-col justify-center min-h-[300px] lg:min-h-[400px]">
          <div class="space-y-8">
            <div>
              <p class="text-[13.5px] leading-relaxed text-cream/80">Das feelMOOR vereint drei Welten unter einem Dach: die heilsame Kraft der Moorheilkunde, moderne Wellness und ehrliche Gastfreundschaft.</p>
            </div>
            <div class="border-t border-cream/20 pt-8">
              <p class="text-[11px] tracking-widest uppercase text-gold mb-3">Ein Gesundresort der Extraklasse</p>
              <p class="text-[13.5px] text-cream/70">Zertifiziert als Moorheilbad, ausgezeichnet für Wellness und Nachhaltigkeit – damit Ihr Aufenthalt mehr ist als nur Entspannung.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Three Highlights Grid ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
        {/* Highlight 1 */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">{page.highlight_1_heading}</h3>
          <p class="text-[13.5px] text-ink-muted mt-4 leading-relaxed">{page.highlight_1_body}</p>
          <div class="mt-6 pt-6 border-t border-stone-light/50">
            <a href="/therme" class="inline-flex items-center gap-2 text-[12px] text-gold font-medium hover:gap-3 transition-all">
              Erfahren Sie mehr
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        {/* Highlight 2 */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">{page.highlight_2_heading}</h3>
          <p class="text-[13.5px] text-ink-muted mt-4 leading-relaxed">{page.highlight_2_body}</p>
          <div class="mt-6 pt-6 border-t border-stone-light/50">
            <a href="/therme" class="inline-flex items-center gap-2 text-[12px] text-gold font-medium hover:gap-3 transition-all">
              Erfahren Sie mehr
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        {/* Highlight 3 */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">{page.highlight_3_heading}</h3>
          <p class="text-[13.5px] text-ink-muted mt-4 leading-relaxed">{page.highlight_3_body}</p>
          <div class="mt-6 pt-6 border-t border-stone-light/50">
            <a href="/en" class="inline-flex items-center gap-2 text-[12px] text-gold font-medium hover:gap-3 transition-all">
              Erfahren Sie mehr
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Sub-page Navigation ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">Entdecken Sie das Resort</h2>
        <p class="text-[13.5px] text-ink-muted mt-3">Alles, was Sie über Zimmer, Wellness und Atmosphäre wissen müssen.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <a href="/hotel/resortuebersicht" class="group bg-white border border-stone-light hover:border-gold/30 p-8 lg:p-10 transition-all">
          <div class="flex items-start justify-between mb-4">
            <h3 class="font-display font-light text-ink-dark text-lg">Resortsübersicht</h3>
            <svg class="w-4 h-4 text-gold opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 14 14" fill="none">
              <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="text-[13.5px] text-ink-muted">Erfahren Sie mehr über die Räumlichkeiten, Ausstattung und den Layout des feelMOOR.</p>
        </a>

        <a href="/zimmer" class="group bg-white border border-stone-light hover:border-gold/30 p-8 lg:p-10 transition-all">
          <div class="flex items-start justify-between mb-4">
            <h3 class="font-display font-light text-ink-dark text-lg">Zimmer & Suiten</h3>
            <svg class="w-4 h-4 text-gold opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 14 14" fill="none">
              <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="text-[13.5px] text-ink-muted">Entdecken Sie unsere Einzelzimmer, Doppelzimmer und exklusiven Suiten.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-[13px] text-ink-muted mt-3 mb-8">Prüfen Sie die Verfügbarkeit oder kontaktieren Sie uns direkt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>

</PageLayout>
