---
import PageLayout from '@/layouts/PageLayout.astro';
import { fetchPage } from '@/lib/storyblok';
import datenschutzFallback from '@/content/pages/datenschutz.json';

const page = (await fetchPage('datenschutz')) ?? datenschutzFallback;
---

<PageLayout title={page.seo_title} description={page.seo_description} noindex={true}>

  <!-- ── Simple Heading Section ── -->
  <section class="py-16 bg-cream">
    <div class="max-w-2xl mx-auto px-6">
      <h1 class="font-display font-light text-ink-dark mb-10" style="font-size:2.5rem;">{page.heading}</h1>
    </div>
  </section>

  <!-- ── Data Protection Content ── -->
  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-6 space-y-10">

      {/* Intro */}
      <div>
        <p class="text-xs text-ink-muted leading-relaxed">{page.intro}</p>
      </div>

      {/* Responsible */}
      <div class="border-t border-stone-light pt-8">
        <h2 class="font-display font-light text-ink-dark mb-4" style="font-size:1.5rem;">{page.section_responsible_heading}</h2>
        <p class="text-xs text-ink-muted leading-relaxed">{page.section_responsible_body}</p>
      </div>

      {/* Data Collection */}
      <div class="border-t border-stone-light pt-8">
        <h2 class="font-display font-light text-ink-dark mb-4" style="font-size:1.5rem;">{page.section_data_heading}</h2>
        <p class="text-xs text-ink-muted leading-relaxed">{page.section_data_body}</p>
      </div>

      {/* Cookies */}
      <div class="border-t border-stone-light pt-8">
        <h2 class="font-display font-light text-ink-dark mb-4" style="font-size:1.5rem;">{page.section_cookies_heading}</h2>
        <p class="text-xs text-ink-muted leading-relaxed">{page.section_cookies_body}</p>
      </div>

      {/* Rights */}
      <div class="border-t border-stone-light pt-8">
        <h2 class="font-display font-light text-ink-dark mb-4" style="font-size:1.5rem;">{page.section_rights_heading}</h2>
        <p class="text-xs text-ink-muted leading-relaxed">{page.section_rights_body}</p>
      </div>

      {/* DPO Contact */}
      <div class="border-t border-stone-light pt-8">
        <p class="text-xs text-ink-muted">{page.contact_dpo}</p>
      </div>

      {/* Link to Impressum */}
      <div class="border-t border-stone-light pt-8">
        <a href="/impressum" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
          Zum Impressum
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
            <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

  <!-- ── Back Link ── -->
  <section class="py-12 bg-cream border-t border-stone-light">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <a href="/" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
        Zurück zur Startseite
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</PageLayout>
