---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import { fetchPage } from '@/lib/storyblok';
import gutscheineFallback from '@/content/pages/gutscheine.json';

const page = (await fetchPage('gutscheine')) ?? gutscheineFallback;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Gutscheine' }]}
  />

  <!-- ── Intro Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Geschenke</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        <div class="bg-forest-700 p-8 lg:p-12 text-cream rounded-sm flex flex-col justify-center min-h-[300px] lg:min-h-[400px]">
          <p class="font-display font-light text-cream text-xl lg:text-2xl leading-snug">{page.intro_quote}</p>
          <div class="border-t border-cream/20 pt-6 mt-8">
            <p class="text-xs tracking-widest uppercase text-gold">feelMOMENTS Geschenkgutscheine</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Voucher categories ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="max-w-2xl mb-12">
        <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">{page.categories_heading}</h2>
        <p class="text-xs text-ink-muted mt-4 leading-relaxed">{page.categories_intro}</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
        {page.categories?.map((cat) => (
          <div class="bg-white border border-stone-light flex flex-col overflow-hidden">
            {cat.image && (
              <div class="aspect-[4/3] overflow-hidden">
                <img src={cat.image} alt={cat.name} loading="lazy" class="w-full h-full object-cover" />
              </div>
            )}
            <div class="p-8 lg:p-10 flex flex-col flex-1">
            <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.6rem);">{cat.name}</h3>
            <div class="mt-auto pt-6 border-t border-stone-light/50">
              <a href={page.cta_buy_href} class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
                {page.cta_buy_label}
                <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── How it works ── -->
  <section class="py-16 bg-cream border-t border-stone-light">
    <div class="max-w-2xl mx-auto px-6">
      <h3 class="font-display font-light text-ink-dark mb-8 text-center" style="font-size:1.75rem;">{page.steps_heading}</h3>
      <ol class="space-y-5">
        {page.steps?.map((step, i) => (
          <li class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center h-6 w-6 rounded-full bg-gold text-forest-700 text-xs font-bold">{i + 1}</div>
            </div>
            <p class="text-xs text-ink-muted leading-relaxed pt-0.5">{step}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Partner ── -->
  {page.partner_heading && (
    <section class="py-12 bg-white border-t border-stone-light">
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h3 class="font-display font-light text-ink-dark mb-4" style="font-size:1.5rem;">{page.partner_heading}</h3>
        <p class="text-xs text-ink-muted leading-relaxed">{page.partner_body}</p>
      </div>
    </section>
  )}

  <!-- ── Bottom CTA ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Jetzt Gutschein anfragen</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Kontaktieren Sie uns für die Erstellung Ihres persönlichen feelMOOR Gutscheins.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/service-kontakt" class="btn-gold">Kontaktieren Sie uns</a>
        <a href="/" class="btn-outline-gold">Zurück zur Startseite</a>
      </div>
    </div>
  </section>

</PageLayout>
