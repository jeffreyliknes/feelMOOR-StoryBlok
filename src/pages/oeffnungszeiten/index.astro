---
import PageLayout from '@/layouts/PageLayout.astro';
import pageData from '@/content/pages/oeffnungszeiten.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <!-- ── Page Hero ── -->
  <section class="relative py-24 lg:py-32 bg-forest-700 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-800 via-forest-700 to-forest-600">
      <div class="absolute inset-0 opacity-10"
           style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22/%3E%3C/svg%3E')">
      </div>
    </div>
    <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center">
      <p class="caption-label mb-4">{page.hero_caption}</p>
      <h1 class="font-display font-light text-cream" style="font-size:clamp(2.5rem,6vw,5rem);line-height:1.06;">{page.hero_heading}</h1>
      <p class="text-cream/70 text-[14px] max-w-xl mx-auto mt-5 leading-relaxed">{page.hero_intro}</p>
      <nav class="mt-8 flex items-center justify-center gap-2 text-[11px] text-cream/40">
        <a href="/" class="hover:text-cream/70 transition-colors">Start</a>
        <span>›</span>
        <span class="text-cream/60">Öffnungszeiten</span>
      </nav>
    </div>
  </section>

  <!-- ── Opening Hours Grid ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {/* Therme */}
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.25rem;">Therme</h3>
          <div class="space-y-3">
            <div>
              <p class="text-[11px] tracking-widest uppercase text-gold mb-1">Montag – Freitag</p>
              <p class="text-[13.5px] text-ink-dark font-medium">09:00 – 21:00 Uhr</p>
            </div>
            <div>
              <p class="text-[11px] tracking-widest uppercase text-gold mb-1">Samstag – Sonntag</p>
              <p class="text-[13.5px] text-ink-dark font-medium">08:00 – 22:00 Uhr</p>
            </div>
          </div>
        </div>

        {/* Fitnessclub */}
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.25rem;">Fitnessclub</h3>
          <div class="space-y-3">
            <div>
              <p class="text-[11px] tracking-widest uppercase text-gold mb-1">Montag – Freitag</p>
              <p class="text-[13.5px] text-ink-dark font-medium">06:30 – 22:00 Uhr</p>
            </div>
            <div>
              <p class="text-[11px] tracking-widest uppercase text-gold mb-1">Samstag – Sonntag</p>
              <p class="text-[13.5px] text-ink-dark font-medium">08:00 – 20:00 Uhr</p>
            </div>
          </div>
        </div>

        {/* Restaurant */}
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.25rem;">Restaurant</h3>
          <div class="space-y-3">
            <div>
              <p class="text-[11px] tracking-widest uppercase text-gold mb-1">Täglich</p>
              <p class="text-[13.5px] text-ink-dark font-medium">Frühstück: 07:00 – 10:00</p>
              <p class="text-[13.5px] text-ink-dark font-medium">Mittag: 12:00 – 14:00</p>
              <p class="text-[13.5px] text-ink-dark font-medium">Abend: 18:30 – 21:00</p>
            </div>
          </div>
        </div>

        {/* Rezeption */}
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.25rem;">Rezeption</h3>
          <div class="space-y-3">
            <div>
              <p class="text-[11px] tracking-widest uppercase text-gold mb-1">Täglich</p>
              <p class="text-[13.5px] text-ink-dark font-medium">07:00 – 22:00 Uhr</p>
            </div>
            <div class="pt-3 mt-3 border-t border-stone-light/50">
              <p class="text-[11px] text-ink-muted">Außerhalb dieser Zeit erreichbar über die Hotline oder per Notfall-Buzzer.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Holiday Note ── -->
  <section class="py-12 bg-stone-light/30 border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="max-w-2xl mx-auto bg-white border border-stone-light p-8 rounded-sm">
        <p class="text-[11px] tracking-widest uppercase text-gold mb-3">Wichtiger Hinweis</p>
        <p class="text-[13.5px] text-ink-muted leading-relaxed">{page.note}</p>
      </div>
    </div>
  </section>

  <!-- ── Contact Link ── -->
  <section class="py-12 bg-cream border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <p class="text-[13.5px] text-ink-muted mb-4">Haben Sie Fragen zu unseren Öffnungszeiten?</p>
      <a href="/service-kontakt" class="inline-flex items-center gap-2 text-[12px] text-gold font-medium hover:gap-3 transition-all">
        Kontaktieren Sie uns
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</PageLayout>
