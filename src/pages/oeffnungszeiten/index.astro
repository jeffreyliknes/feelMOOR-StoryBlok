---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import { fetchPage } from '@/lib/storyblok';
import oeffnungszeitenFallback from '@/content/pages/oeffnungszeiten.json';

const page = (await fetchPage('oeffnungszeiten')) ?? oeffnungszeitenFallback;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Öffnungszeiten' }]}
  />

  <!-- ── Opening Hours Grid ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {/* Therme */}
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.25rem;">Therme</h3>
          <div class="space-y-3">
            <div>
              <p class="text-xs tracking-widest uppercase text-gold mb-1">Montag bis Freitag</p>
              <p class="text-xs text-ink-dark font-medium">09:00 bis 21:00 Uhr</p>
            </div>
            <div>
              <p class="text-xs tracking-widest uppercase text-gold mb-1">Samstag bis Sonntag</p>
              <p class="text-xs text-ink-dark font-medium">08:00 bis 22:00 Uhr</p>
            </div>
          </div>
        </div>

        {/* Fitnessclub */}
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.25rem;">Fitnessclub</h3>
          <div class="space-y-3">
            <div>
              <p class="text-xs tracking-widest uppercase text-gold mb-1">Montag bis Freitag</p>
              <p class="text-xs text-ink-dark font-medium">06:30 bis 22:00 Uhr</p>
            </div>
            <div>
              <p class="text-xs tracking-widest uppercase text-gold mb-1">Samstag bis Sonntag</p>
              <p class="text-xs text-ink-dark font-medium">08:00 bis 20:00 Uhr</p>
            </div>
          </div>
        </div>

        {/* Restaurant */}
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.25rem;">Restaurant</h3>
          <div class="space-y-3">
            <div>
              <p class="text-xs tracking-widest uppercase text-gold mb-1">Täglich</p>
              <p class="text-xs text-ink-dark font-medium">Frühstück: 07:00 bis 10:00</p>
              <p class="text-xs text-ink-dark font-medium">Mittag: 12:00 bis 14:00</p>
              <p class="text-xs text-ink-dark font-medium">Abend: 18:30 bis 21:00</p>
            </div>
          </div>
        </div>

        {/* Rezeption */}
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <h3 class="font-display font-light text-ink-dark mb-6" style="font-size:1.25rem;">Rezeption</h3>
          <div class="space-y-3">
            <div>
              <p class="text-xs tracking-widest uppercase text-gold mb-1">Täglich</p>
              <p class="text-xs text-ink-dark font-medium">07:00 bis 22:00 Uhr</p>
            </div>
            <div class="pt-3 mt-3 border-t border-stone-light/50">
              <p class="text-xs text-ink-muted">Außerhalb dieser Zeit erreichbar über die Hotline oder per Notfall-Buzzer.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Holiday Note ── -->
  <section class="py-12 bg-stone-light/30 border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="max-w-2xl mx-auto bg-white border border-stone-light p-8 rounded-sm">
        <p class="text-xs tracking-widest uppercase text-gold mb-3">Wichtiger Hinweis</p>
        <p class="text-xs text-ink-muted leading-relaxed">{page.note}</p>
      </div>
    </div>
  </section>

  <!-- ── Contact Link ── -->
  <section class="py-12 bg-cream border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <p class="text-xs text-ink-muted mb-4">Haben Sie Fragen zu unseren Öffnungszeiten?</p>
      <a href="/service-kontakt" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
        Kontaktieren Sie uns
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</PageLayout>
