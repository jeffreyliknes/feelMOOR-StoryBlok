---
import PageLayout from '@/layouts/PageLayout.astro';
import pageData from '@/content/pages/impressum.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description} noindex={true}>

  <!-- ── Simple Heading Section ── -->
  <section class="py-16 bg-cream">
    <div class="max-w-2xl mx-auto px-6">
      <h1 class="font-display font-light text-ink-dark mb-10" style="font-size:2.5rem;">{page.heading}</h1>
    </div>
  </section>

  <!-- ── Legal Content ── -->
  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-6 space-y-12">

      {/* Company Info */}
      <div>
        <h2 class="font-display font-light text-ink-dark mb-4" style="font-size:1.5rem;">{page.company_name}</h2>
        <p class="text-xs text-ink-muted mb-4">{page.company_subtitle}</p>
        <div class="text-xs text-ink-muted space-y-2">
          <p>{page.address_street}</p>
          <p>{page.address_zip_city}</p>
        </div>
      </div>

      {/* Register Info */}
      <div class="border-t border-stone-light pt-8">
        <div class="text-xs text-ink-muted space-y-3">
          <p>{page.register_court}</p>
          <p>{page.register_number}</p>
          <p>{page.vat_id}</p>
        </div>
      </div>

      {/* Managing Director */}
      <div class="border-t border-stone-light pt-8">
        <p class="text-xs text-ink-muted">{page.managing_director}</p>
      </div>

      {/* Content Responsible */}
      <div class="border-t border-stone-light pt-8">
        <h3 class="font-display font-light text-ink-dark mb-3" style="font-size:1.25rem;">Verantwortlicher</h3>
        <p class="text-xs text-ink-muted leading-relaxed">{page.content_responsible}</p>
      </div>

      {/* Liability */}
      <div class="border-t border-stone-light pt-8">
        <h3 class="font-display font-light text-ink-dark mb-3" style="font-size:1.25rem;">Haftung</h3>
        <p class="text-xs text-ink-muted leading-relaxed">{page.liability_text}</p>
      </div>

      {/* External Links */}
      <div class="border-t border-stone-light pt-8">
        <h3 class="font-display font-light text-ink-dark mb-3" style="font-size:1.25rem;">Externe Links</h3>
        <p class="text-xs text-ink-muted leading-relaxed">{page.links_text}</p>
      </div>

      {/* Data Protection Link */}
      <div class="border-t border-stone-light pt-8">
        <a href="/datenschutz" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
          Zur Datenschutzerklärung
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
            <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

  <!-- ── Back Link ── -->
  <section class="py-12 bg-cream border-t border-stone-light">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <a href="/" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
        Zurück zur Startseite
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</PageLayout>
