---
import PageLayout from '@/layouts/PageLayout.astro';
import priceData from '@/content/pages/therme-preise.json';

const page = priceData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <!-- ── Page Hero ── -->
  <section class="relative py-24 lg:py-32 bg-forest-700 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-800 via-forest-700 to-forest-600">
      <div class="absolute inset-0 opacity-10"
           style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22/%3E%3C/svg%3E')">
      </div>
    </div>
    <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center">
      <p class="caption-label mb-4">{page.hero_caption}</p>
      <h1 class="font-display font-light text-cream" style="font-size:clamp(2.5rem,6vw,5rem);line-height:1.06;">{page.hero_heading}</h1>
      <p class="text-cream/70 text-sm max-w-xl mx-auto mt-5 leading-relaxed">{page.hero_intro}</p>
      <nav class="mt-8 flex items-center justify-center gap-2 text-xs text-cream/40">
        <a href="/" class="hover:text-cream/70 transition-colors">Start</a>
        <span>›</span>
        <a href="/therme" class="hover:text-cream/70 transition-colors">Therme</a>
        <span>›</span>
        <span class="text-cream/60">Preise & Tarife</span>
      </nav>
    </div>
  </section>

  <!-- ── Hotel Guest Info Strip ── -->
  <section class="py-16 bg-gold/5 border-b border-gold/20">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="bg-gradient-to-r from-gold/10 to-gold/5 border border-gold/30 p-8 lg:p-10 rounded-sm">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-gold/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-gold" viewBox="0 0 24 24" fill="none">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z" fill="currentColor"/>
            </svg>
          </div>
          <div>
            <h3 class="font-display font-light text-ink-dark text-lg mb-2">Für Hotelgäste inklusive</h3>
            <p class="text-xs text-ink-muted leading-relaxed">{page.note_hotel_guests}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Day Guest Info Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="max-w-3xl mx-auto">
        <p class="caption-label mb-4 text-gold">Für Tagesgäste</p>
        <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">Eintrittspreise Tagesgäste</h2>
        <p class="text-xs text-ink-muted mt-6 leading-relaxed">{page.note_day_guests}</p>
      </div>
    </div>
  </section>

  <!-- ── Price Table ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="bg-white border border-stone-light overflow-hidden rounded-sm">
        <table class="w-full">
          <thead class="bg-forest-700">
            <tr>
              <th class="text-left px-6 py-4 text-cream font-display font-light text-base">Kategorien</th>
              <th class="text-center px-6 py-4 text-cream font-display font-light text-base">2 Std.</th>
              <th class="text-center px-6 py-4 text-cream font-display font-light text-base">4 Std.</th>
              <th class="text-center px-6 py-4 text-cream font-display font-light text-base">Tageskarte</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-stone-light">
              <td class="px-6 py-4 text-xs text-ink-dark font-medium">Erwachsene</td>
              <td class="px-6 py-4 text-xs text-ink-muted text-center">€ 12,00</td>
              <td class="px-6 py-4 text-xs text-ink-muted text-center">€ 18,00</td>
              <td class="px-6 py-4 text-xs text-ink-dark font-medium text-center">€ 24,00</td>
            </tr>
            <tr class="border-b border-stone-light">
              <td class="px-6 py-4 text-xs text-ink-dark font-medium">Kinder (4 bis 15 Jahre)</td>
              <td class="px-6 py-4 text-xs text-ink-muted text-center">€ 7,00</td>
              <td class="px-6 py-4 text-xs text-ink-muted text-center">€ 11,00</td>
              <td class="px-6 py-4 text-xs text-ink-dark font-medium text-center">€ 15,00</td>
            </tr>
            <tr class="bg-gold/5">
              <td class="px-6 py-4 text-xs text-ink-dark font-medium">Familie (2 Erw. + 2 Ki.)</td>
              <td class="px-6 py-4 text-xs text-ink-muted text-center">€ 28,00</td>
              <td class="px-6 py-4 text-xs text-ink-muted text-center">€ 42,00</td>
              <td class="px-6 py-4 text-xs text-ink-dark font-medium text-center">€ 56,00</td>
            </tr>
            <tr class="border-t border-stone-light">
              <td class="px-6 py-4 text-xs text-ink-light italic">Senioren (ab 65 J.), 10% Rabatt</td>
              <td colspan="3" class="px-6 py-4 text-xs text-ink-light">Mit Nachweis erhältlich an der Rezeption</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-ink-light mt-4">Preise inkl. Thermalbad und Saunalandschaft. Wellness-Anwendungen kosten extra.</p>
    </div>
  </section>

  <!-- ── Opening Hours ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="max-w-2xl mx-auto">
        <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Öffnungszeiten</h2>
        <div class="mt-8 grid md:grid-cols-2 gap-8">
          <div class="border border-stone-light p-6 rounded-sm">
            <p class="text-xs text-ink-light tracking-widest uppercase mb-4">Mo, Fr</p>
            <p class="text-xs text-ink-dark font-medium">09:00 bis 21:00 Uhr</p>
            <p class="text-xs text-ink-light mt-2">Letzte Einfahrt: 20:00 Uhr</p>
          </div>
          <div class="border border-stone-light p-6 rounded-sm">
            <p class="text-xs text-ink-light tracking-widest uppercase mb-4">Sa, So & Feiertage</p>
            <p class="text-xs text-ink-dark font-medium">08:00 bis 21:00 Uhr</p>
            <p class="text-xs text-ink-light mt-2">Letzte Einfahrt: 20:00 Uhr</p>
          </div>
        </div>
        <p class="text-xs text-ink-light mt-6 leading-relaxed">
          <strong>Hinweis:</strong> An Feiertagen und während besonderer Veranstaltungen können die Öffnungszeiten abweichen. Bitte informieren Sie sich aktuell.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Contact & Questions ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30 border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="max-w-2xl mx-auto bg-white border border-stone-light p-8 lg:p-10 rounded-sm text-center">
        <h3 class="font-display font-light text-ink-dark text-lg mb-3">Fragen zu den Preisen?</h3>
        <p class="text-xs text-ink-muted mb-6 leading-relaxed">Kontaktieren Sie uns direkt oder besuchen Sie uns. Wir beraten Sie gerne zu Preisvergünstigungen, Gruppentarifen und speziellen Angeboten.</p>
        <a href="/service-kontakt" class="btn-gold inline-block">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Prüfen Sie die Verfügbarkeit oder kontaktieren Sie uns direkt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>

</PageLayout>
