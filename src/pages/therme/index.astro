---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import ContentImage from '@/components/common/ContentImage.astro';
import { getStory } from '@/lib/storyblok';

const page = await getStory('pages/therme', Astro);
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Therme & Spa' }]}
  />

  <!-- ── Stats Bar ── -->
  <section class="py-12 bg-forest-700 border-b border-forest-600">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid grid-cols-3 gap-8 text-center">
        <div>
          <p class="font-display font-light text-cream" style="font-size:clamp(1.75rem,3vw,2.5rem);">{page.stat_1_value}</p>
          <p class="text-xs text-cream/60 mt-2 tracking-widest uppercase">{page.stat_1_label}</p>
        </div>
        <div>
          <p class="font-display font-light text-cream" style="font-size:clamp(1.75rem,3vw,2.5rem);">{page.stat_2_value}</p>
          <p class="text-xs text-cream/60 mt-2 tracking-widest uppercase">{page.stat_2_label}</p>
        </div>
        <div>
          <p class="font-display font-light text-cream" style="font-size:clamp(1.75rem,3vw,2.5rem);">{page.stat_3_value}</p>
          <p class="text-xs text-cream/60 mt-2 tracking-widest uppercase">{page.stat_3_label}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Intro Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Die Therme</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        {page.intro_image && (
          <ContentImage
            src={page.intro_image}
            alt="Thermalbad und Wasserwelt, feelMOOR Therme"
          />
        )}
      </div>
    </div>
  </section>

  <!-- ── Navigation Cards ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">Erkunden Sie die Therme</h2>
        <p class="text-xs text-ink-muted mt-3">Alles über unsere Thermalbäder, Saunen und Wellness-Anwendungen.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {/* Thermalbad */}
        <a href="/therme/thermalbad" class="group bg-white border border-stone-light hover:border-gold/30 overflow-hidden transition-all">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="/images/therme/therme-2.webp" alt="Thermalbad feelMOOR" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-8 lg:p-10">
          <div class="flex items-start justify-between mb-4">
            <h3 class="font-display font-light text-ink-dark text-lg">Thermalbad</h3>
            <svg class="w-4 h-4 text-gold opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 14 14" fill="none">
              <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="text-xs text-ink-muted">34 °C warmes Mineralwasser, Strömungskanal und Außenpool das ganze Jahr.</p>
          </div>
        </a>

        {/* Sauna */}
        <a href="/therme/sauna" class="group bg-white border border-stone-light hover:border-gold/30 overflow-hidden transition-all">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="/images/therme/sauna-1.webp" alt="Saunalandschaft feelMOOR" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-8 lg:p-10">
          <div class="flex items-start justify-between mb-4">
            <h3 class="font-display font-light text-ink-dark text-lg">Saunalandschaft</h3>
            <svg class="w-4 h-4 text-gold opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 14 14" fill="none">
              <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="text-xs text-ink-muted">7 Saunen, Dampfbad, Erlebnisduschen und großzügige Ruhebereiche.</p>
          </div>
        </a>

        {/* Wellness */}
        <a href="/therme/wellness" class="group bg-white border border-stone-light hover:border-gold/30 overflow-hidden transition-all">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="/images/wellness/Massage.webp" alt="Wellness und Spa feelMOOR" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-8 lg:p-10">
          <div class="flex items-start justify-between mb-4">
            <h3 class="font-display font-light text-ink-dark text-lg">Wellness & Spa</h3>
            <svg class="w-4 h-4 text-gold opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 14 14" fill="none">
              <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="text-xs text-ink-muted">Massagen, Mooranwendungen und Schönheitsbehandlungen von Profis.</p>
          </div>
        </a>

        {/* Preise */}
        <a href="/therme/preise" class="group bg-white border border-stone-light hover:border-gold/30 overflow-hidden transition-all">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="/images/therme/outdoor-pool.webp" alt="Therme feelMOOR" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-8 lg:p-10">
          <div class="flex items-start justify-between mb-4">
            <h3 class="font-display font-light text-ink-dark text-lg">Preise & Tarife</h3>
            <svg class="w-4 h-4 text-gold opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 14 14" fill="none">
              <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="text-xs text-ink-muted">Eintrittspreise für Tagesgäste, Hotelgäste genießen freien Zugang.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihre Wellness-Auszeit?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Buchen Sie Ihren Aufenthalt oder fragen Sie nach Tagesgästen-Angeboten.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>

</PageLayout>
