---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import ContentImage from '@/components/common/ContentImage.astro';
import pageData from '@/content/pages/allgaeu.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Allgäu erleben' }]}
  />

  <!-- ── Intro Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Entdecken</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        {page.intro_image && (
          <ContentImage
            src={page.intro_image}
            alt="Aktivitäten und Natur im Allgäu"
          />
        )}
      </div>
    </div>
  </section>

  <!-- ── Activity Grid ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8">
        {page.activities?.map((act) => (
          <div class="bg-white border border-stone-light overflow-hidden flex flex-col">
            {act.image && (
              <div class="aspect-[4/3] overflow-hidden">
                <img src={act.image} alt={act.title} loading="lazy" class="w-full h-full object-cover" />
              </div>
            )}
            <div class="p-8 lg:p-10 flex flex-col flex-1">
              <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">{act.title}</h3>
              <p class="text-xs text-ink-muted mt-4 leading-relaxed flex-1">{act.body}</p>
              {act.href && (
                <a href={act.href} class="inline-flex items-center gap-2 mt-6 text-xs text-gold font-medium hover:gap-3 transition-all">
                  Mehr erfahren
                  <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none"><path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Feature sections ── -->
  {page.features?.map((feature, i) => (
    <section class={`py-16 lg:py-24 border-t border-stone-light ${i % 2 === 0 ? 'bg-cream' : 'bg-white'}`}>
      <div class="max-w-screen-xl mx-auto px-6">
        <div class={`grid gap-10 lg:gap-16 items-start ${feature.image ? 'lg:grid-cols-2' : 'max-w-3xl mx-auto'}`}>
          {feature.image && (
            <img src={feature.image} alt={feature.image_alt ?? feature.heading} class="w-full aspect-[4/3] object-cover rounded-xl" loading="lazy" />
          )}
          <div>
            <h2 class="font-display font-light text-ink-dark mb-6" style="font-size:clamp(1.5rem,3vw,2.25rem);">{feature.heading}</h2>
            <div class="space-y-4">
              {feature.paragraphs?.map((p) => (
                <p class="text-xs text-ink-muted leading-relaxed">{p}</p>
              ))}
            </div>
            {feature.links && feature.links.length > 0 && (
              <div class="flex flex-wrap gap-4 mt-6">
                {feature.links.map((link) => (
                  <a href={link.href} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
                    {link.label}
                    <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                      <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ── Bottom CTA (Modified) ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Entdecken Sie das Allgäu</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Buchen Sie Ihren Aufenthalt und profitieren Sie von unserer zentralen Lage.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Zimmer buchen</a>
        <a href="/hotel" class="btn-outline-gold">Zum Resort</a>
      </div>
    </div>
  </section>

</PageLayout>
