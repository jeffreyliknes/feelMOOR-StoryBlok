---
import PageLayout from '@/layouts/PageLayout.astro';
import pageData from '@/content/pages/allgaeu.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <!-- ── Page Hero ── -->
  <section class="relative py-24 lg:py-32 bg-forest-700 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-800 via-forest-700 to-forest-600">
      <div class="absolute inset-0 opacity-10"
           style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22/%3E%3C/svg%3E')">
      </div>
    </div>
    <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center">
      <p class="caption-label mb-4">{page.hero_caption}</p>
      <h1 class="font-display font-light text-cream" style="font-size:clamp(2.5rem,6vw,5rem);line-height:1.06;">{page.hero_heading}</h1>
      <p class="text-cream/70 text-sm max-w-xl mx-auto mt-5 leading-relaxed">{page.hero_intro}</p>
      <nav class="mt-8 flex items-center justify-center gap-2 text-xs text-cream/40">
        <a href="/" class="hover:text-cream/70 transition-colors">Start</a>
        <span>›</span>
        <span class="text-cream/60">Allgäu erleben</span>
      </nav>
    </div>
  </section>

  <!-- ── Intro Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Entdecken</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        <div class="bg-forest-700 p-8 lg:p-12 text-cream rounded-sm flex flex-col justify-center min-h-[300px] lg:min-h-[400px]">
          <div class="space-y-8">
            <div>
              <p class="text-xs leading-relaxed text-cream/80">Nur wenige Kilometer vom feelMOOR entfernt finden Sie eine Welt voller Möglichkeiten, Natur, Aktivität und Kultur in perfekter Harmonie.</p>
            </div>
            <div class="border-t border-cream/20 pt-8">
              <p class="text-xs tracking-widest uppercase text-gold mb-3">Ideal für aktive Gäste</p>
              <p class="text-xs text-cream/70">Entdecken Sie das Allgäu und kehren Sie am Abend zur Ruhe ins feelMOOR zurück.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 6-Card Activity Grid ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {/* Wandern */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Wandern</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Unzählige Wanderwege führen durch Moorlandschaften und sanfte Allgäuer Hügel, für jedes Fitnesslevel.</p>
        </div>

        {/* Radfahren */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Radfahren</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Markierte Fahrradrouten verbinden Dörfer und Sehenswürdigkeiten, perfekt für einen aktiven Tag.</p>
        </div>

        {/* Moorerlebnis */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Moorerlebnis</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Das Wurzacher Ried erkunden, Besucherzentrum, Moorlehrpfade und unberührte Natur warten auf Sie.</p>
        </div>

        {/* Ausflugsziele */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Ausflugsziele</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Burgen, Schlösser und historische Städte wie Isny und Leutkirch sind schnell erreichbar.</p>
        </div>

        {/* Wintersport */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Wintersport</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Langlauf-Loipen und Skigebiete in den nahen Alpen machen Winter zu einer aktiven Jahreszeit.</p>
        </div>

        {/* Kulturerlebnisse */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Kulturerlebnisse</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Museen, handwerkliche Traditionen und lokale Feste zeigen Ihnen die Allgäuer Kultur aus nächster Nähe.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Tipps vom Team Strip ── -->
  <section class="py-12 bg-cream border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h3 class="font-display font-light text-ink-dark mb-4" style="font-size:1.5rem;">Tipps vom feelMOOR-Team</h3>
      <p class="text-xs text-ink-muted mb-6">Unser Team kennt die schönsten Ecken der Region und gibt Ihnen gerne persönliche Empfehlungen. Fragen Sie an der Rezeption nach lokalen Geheimtipps und aktuellen Veranstaltungen.</p>
      <a href="/service-kontakt" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
        Kontaktieren Sie uns
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Bottom CTA (Modified) ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Entdecken Sie das Allgäu</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Buchen Sie Ihren Aufenthalt und profitieren Sie von unserer zentralen Lage.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Zimmer buchen</a>
        <a href="/hotel" class="btn-outline-gold">Zum Resort</a>
      </div>
    </div>
  </section>

</PageLayout>
