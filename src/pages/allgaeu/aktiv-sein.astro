---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import { getStory, lines } from '@/lib/storyblok';

const page = await getStory('pages/allgaeu-aktiv-sein', Astro);
---

<PageLayout title={page.seo_title} description={page.seo_description}>
  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Allgäu erleben', href: '/allgaeu' }, { label: 'Aktiv sein' }]}
  />

  <section class="py-6 bg-white border-b border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6">
      <a href="/allgaeu" class="text-gold text-xs font-semibold uppercase tracking-wide hover:text-gold/80 transition-colors">← Allgäu erleben</a>
    </div>
  </section>

  {(page.sections ?? []).map((section, i) => (
    <section class={`py-16 lg:py-24 ${i % 2 === 0 ? 'bg-cream' : 'bg-white'}`}>
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
          <div class={i % 2 !== 0 ? 'lg:order-2' : ''}>
            <h2 class="font-display font-light text-ink-dark mb-6" style="font-size:clamp(1.75rem,3.5vw,3rem);">{section.heading}</h2>
            <div class="space-y-4">
              {lines(section.paragraphs).map((p) => (
                <p class="text-xs text-ink-muted leading-relaxed">{p}</p>
              ))}
            </div>
            {section.highlight_heading && (
              <div class="mt-8 p-6 bg-forest-700/5 border-l-4 border-gold">
                <h3 class="font-display font-light text-ink-dark text-xl mb-3">{section.highlight_heading}</h3>
                <p class="text-xs text-ink-muted leading-relaxed">{section.highlight_body}</p>
                {section.highlight_link_href && (
                  <a href={section.highlight_link_href} target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-4 text-xs text-gold font-medium hover:gap-3 transition-all">
                    {section.highlight_link_label}
                    <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none"><path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                )}
              </div>
            )}
            {section.hotel_benefits && (
              <div class="mt-8">
                <p class="caption-label text-gold mb-4">Unser Service für Radfahrer</p>
                <ul class="space-y-2">
                  {lines(section.hotel_benefits).map((b) => (
                    <li class="flex items-start gap-3 text-xs text-ink-muted">
                      <span class="text-gold mt-0.5 shrink-0">✓</span>
                      {b}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
          {section.image && (
            <div class={i % 2 !== 0 ? 'lg:order-1' : ''}>
              <img src={section.image} alt={section.image_alt} class="w-full aspect-[4/3] object-cover rounded-sm" loading="lazy" />
            </div>
          )}
        </div>
      </div>
    </section>
  ))}

  <!-- E-Bike Section -->
  <section class="py-16 lg:py-24 bg-forest-700 text-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="caption-label text-gold mb-4">Direkt im Resort</p>
          <h2 class="font-display font-light" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.ebike_heading}</h2>
          <ul class="mt-8 space-y-3">
            {lines(page.ebike_details).map((d) => (
              <li class="flex items-start gap-3 text-xs text-cream/80 leading-relaxed">
                <span class="text-gold mt-0.5 shrink-0">—</span>
                {d}
              </li>
            ))}
          </ul>
          <a href="/service-kontakt" class="btn-gold mt-8 inline-block">E-Bike reservieren</a>
        </div>
        <img src={page.ebike_image} alt={page.ebike_image_alt} class="w-full aspect-[4/3] object-cover rounded-sm" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aktivurlaub?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Buchen Sie Ihren Aufenthalt im feelMOOR und entdecken Sie das Allgäu.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/allgaeu" class="btn-outline-gold">Alle Allgäu-Tipps</a>
      </div>
    </div>
  </section>
</PageLayout>
