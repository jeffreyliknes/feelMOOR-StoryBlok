---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import pageData from '@/content/pages/allgaeu-ausflugsziele.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>
  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Allgäu erleben', href: '/allgaeu' }, { label: 'Ausflugsziele' }]}
  />

  <section class="py-6 bg-white border-b border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6">
      <a href="/allgaeu" class="text-gold text-xs font-semibold uppercase tracking-wide hover:text-gold/80 transition-colors">← Allgäu erleben</a>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <p class="text-sm text-ink-muted text-center max-w-2xl mx-auto">{page.intro}</p>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="space-y-8">
        {page.excursions.map((exc) => (
          <div class="border border-stone-light bg-cream/30 p-8 lg:p-10">
            <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
              <div>
                <p class="caption-label text-gold mb-2">{exc.category}</p>
                <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">{exc.title}</h2>
              </div>
              {exc.link_href && (
                <a href={exc.link_href} target="_blank" rel="noopener" class="btn-outline-gold shrink-0">{exc.link_label}</a>
              )}
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              {exc.meeting_point && (
                <div>
                  <p class="text-xs font-semibold text-ink-dark uppercase tracking-wide mb-1">Treffpunkt</p>
                  <p class="text-xs text-ink-muted">{exc.meeting_point}</p>
                </div>
              )}
              {exc.schedule && (
                <div>
                  <p class="text-xs font-semibold text-ink-dark uppercase tracking-wide mb-1">Termine</p>
                  <p class="text-xs text-ink-muted">{exc.schedule}</p>
                </div>
              )}
              {exc.duration && (
                <div>
                  <p class="text-xs font-semibold text-ink-dark uppercase tracking-wide mb-1">Dauer</p>
                  <p class="text-xs text-ink-muted">{exc.duration}</p>
                </div>
              )}
            </div>
            {exc.highlights && exc.highlights.length > 0 && (
              <ul class="mt-6 space-y-2">
                {exc.highlights.map((h) => (
                  <li class="flex items-start gap-3 text-xs text-ink-muted">
                    <span class="text-gold mt-0.5 shrink-0">✓</span>
                    {h}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Planen Sie Ihren Aufenthalt</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Nutzen Sie unsere zentrale Lage für Ihre Ausflüge in die Region.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/allgaeu" class="btn-outline-gold">Weitere Allgäu-Tipps</a>
      </div>
    </div>
  </section>
</PageLayout>
