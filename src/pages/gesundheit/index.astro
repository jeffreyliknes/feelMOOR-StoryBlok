---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import ContentImage from '@/components/common/ContentImage.astro';
import { fetchPage } from '@/lib/storyblok';
import gesundheitFallback from '@/content/pages/gesundheit.json';

const page = (await fetchPage('gesundheit')) ?? gesundheitFallback;
---

<PageLayout title={page.seo_title} description={page.seo_description}>
  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Gesundheit' }]}
  />

  <!-- Intro Section -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted leading-relaxed mt-6">{page.intro_body}</p>
        </div>
        {page.intro_image ? (
          <ContentImage
            src={page.intro_image}
            alt="Moorlandschaft und Torflehrpfad Bad Wurzach"
          />
        ) : (
          <div class="bg-forest-700 rounded-lg p-8 text-center">
            <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-2">Tradition & Vertrauen</p>
            <div class="text-cream text-[42px] font-display font-light leading-tight mb-4">Seit über 100 Jahren Moorkurort</div>
            <p class="text-cream/70 text-xs leading-relaxed">Das Wurzacher Ried ist eine der wertvollsten Moorlandschaften Europas, und unsere Fachkompetenz reicht über hundert Jahre zurück.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Sub-page Cards -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Moorbad Card -->
        <a href="/gesundheit/moorbad" class="group bg-cream rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="/images/allgaeu/Heilkraft-des-moores.webp" alt="Moorbad Bad Wurzach" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-8">
          <h3 class="font-display font-light text-ink-dark text-[24px] mb-3 group-hover:text-gold transition-colors">Moorbad</h3>
          <p class="text-xs text-ink-muted leading-relaxed mb-6">Das Original-Moorbad aus dem Wurzacher Ried, Heilkraft aus 10.000 Jahren Naturgeschichte.</p>
          <span class="text-gold text-xs font-semibold uppercase tracking-wide">Mehr erfahren →</span>
          </div>
        </a>

        <!-- Anwendungen Card -->
        <a href="/gesundheit/anwendungen" class="group bg-cream rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="/images/wellness/Entschleunigung_Wellness.webp" alt="Gesundheitsanwendungen feelMOOR" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-8">
          <h3 class="font-display font-light text-ink-dark text-[24px] mb-3 group-hover:text-gold transition-colors">Anwendungen</h3>
          <p class="text-xs text-ink-muted leading-relaxed mb-6">Medizinisch fundierte Therapien, von Moorbehandlungen über Physiotherapie bis Elektrotherapie.</p>
          <span class="text-gold text-xs font-semibold uppercase tracking-wide">Mehr erfahren →</span>
          </div>
        </a>

        <!-- Ärzte & Therapeuten Card -->
        <a href="/gesundheit/aerzte-therapeuten" class="group bg-cream rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="/images/bilder-aerzte-therapeuten/3.webp" alt="Ärzte und Therapeuten feelMOOR" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-8">
          <h3 class="font-display font-light text-ink-dark text-[24px] mb-3 group-hover:text-gold transition-colors">Ärzte & Therapeuten</h3>
          <p class="text-xs text-ink-muted leading-relaxed mb-6">Erfahrene Experten begleiten Sie auf Ihrem Weg zu Gesundheit und Wohlbefinden.</p>
          <span class="text-gold text-xs font-semibold uppercase tracking-wide">Mehr erfahren →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Indicator Strip: Medical Conditions -->
  <section class="py-12 bg-forest-700">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div>
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-2">Indikation</p>
          <p class="text-cream text-[16px] font-display font-light">Rheuma & Entzündungen</p>
        </div>
        <div>
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-2">Indikation</p>
          <p class="text-cream text-[16px] font-display font-light">Arthrose & Gelenkschmerzen</p>
        </div>
        <div>
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-2">Indikation</p>
          <p class="text-cream text-[16px] font-display font-light">Orthopädische Beschwerden</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Prüfen Sie die Verfügbarkeit oder kontaktieren Sie uns direkt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>
</PageLayout>
