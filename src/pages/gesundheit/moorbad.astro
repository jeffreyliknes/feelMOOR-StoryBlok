---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import pageData from '@/content/pages/gesundheit-moorbad.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>
  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Gesundheit', href: '/gesundheit' }, { label: 'Moorbad' }]}
  />

  <!-- Back Link -->
  <section class="py-6 bg-white border-b border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6">
      <a href="/gesundheit" class="text-gold text-xs font-semibold uppercase tracking-wide hover:text-gold/80 transition-colors">← Zurück zu Gesundheit</a>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted leading-relaxed mt-6">{page.intro_body}</p>
        </div>
        {page.intro_image && (
          <img
            src={page.intro_image}
            alt="Moorbad und Riedsee Bad Wurzach"
            class="w-full aspect-[4/3] object-cover rounded-sm"
            loading="lazy"
          />
        )}
      </div>
    </div>
  </section>

  <!-- Benefits Grid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-screen-xl mx-auto px-6">
      <h3 class="font-display font-light text-ink-dark text-[28px] mb-12 text-center">Wirkungsweise des Moorbades</h3>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-stone-light/20 rounded-lg p-8">
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-3">Wirkung</p>
          <h4 class="text-ink-dark font-display font-light text-[20px] mb-4">Entzündungshemmend</h4>
          <p class="text-xs text-ink-muted leading-relaxed">Die natürlichen Wirkstoffe des Wurzacher Moores reduzieren Entzündungen und beruhigen gereizte Gelenke und Gewebe.</p>
        </div>
        <div class="bg-stone-light/20 rounded-lg p-8">
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-3">Wirkung</p>
          <h4 class="text-ink-dark font-display font-light text-[20px] mb-4">Schmerzlindernd</h4>
          <p class="text-xs text-ink-muted leading-relaxed">Die intensive Wärme und die Mineralstoffzusammensetzung lindern chronische und akute Schmerzen zuverlässig.</p>
        </div>
        <div class="bg-stone-light/20 rounded-lg p-8">
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-3">Wirkung</p>
          <h4 class="text-ink-dark font-display font-light text-[20px] mb-4">Wärmetiefenwirkung</h4>
          <p class="text-xs text-ink-muted leading-relaxed">Die Moorwärme dringt tief in Muskulatur und Gelenke ein und fördert die Durchblutung nachhaltig.</p>
        </div>
        <div class="bg-stone-light/20 rounded-lg p-8">
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-3">Wirkung</p>
          <h4 class="text-ink-dark font-display font-light text-[20px] mb-4">Muskelentspannung</h4>
          <p class="text-xs text-ink-muted leading-relaxed">Verspannte und verhärtete Muskulatur entspannt sich durch die Wärmewirkung und das Auftriebsgefühl im Bad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Indications -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <h3 class="font-display font-light text-ink-dark text-[28px] mb-12 text-center">Indikationen: Das Moorbad hilft bei</h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg p-6 border-l-4 border-gold">
          <p class="text-ink-dark font-display font-light text-[18px] mb-2">Rheuma</p>
          <p class="text-xs text-ink-muted">Rheumatoide Arthritis und entzündliche Gelenkerkrankungen.</p>
        </div>
        <div class="bg-white rounded-lg p-6 border-l-4 border-gold">
          <p class="text-ink-dark font-display font-light text-[18px] mb-2">Arthrose</p>
          <p class="text-xs text-ink-muted">Verschleiß und Degeneration von Gelenkknorpel.</p>
        </div>
        <div class="bg-white rounded-lg p-6 border-l-4 border-gold">
          <p class="text-ink-dark font-display font-light text-[18px] mb-2">Gelenkschmerzen</p>
          <p class="text-xs text-ink-muted">Allgemeine Gelenkbeschwerden und Steifheit.</p>
        </div>
        <div class="bg-white rounded-lg p-6 border-l-4 border-gold">
          <p class="text-ink-dark font-display font-light text-[18px] mb-2">Muskelverspannungen</p>
          <p class="text-xs text-ink-muted">Chronische Verspannungen und Muskelschmerzen.</p>
        </div>
        <div class="bg-white rounded-lg p-6 border-l-4 border-gold">
          <p class="text-ink-dark font-display font-light text-[18px] mb-2">Sportverletzungen</p>
          <p class="text-xs text-ink-muted">Regeneration nach Belastung und Verletzungen.</p>
        </div>
        <div class="bg-white rounded-lg p-6 border-l-4 border-gold">
          <p class="text-ink-dark font-display font-light text-[18px] mb-2">Nervenschmerzen</p>
          <p class="text-xs text-ink-muted">Chronische Nervenschmerzen und Neuropathien.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Booking Info Strip -->
  <section class="py-12 bg-forest-700 text-center">
    <div class="max-w-screen-xl mx-auto px-6">
      <p class="text-cream text-sm leading-relaxed">
        <span class="text-gold font-semibold">Dauer:</span> 20 Minuten |
        <span class="text-gold font-semibold">Temperatur:</span> 38 bis 42 °C |
        <span class="text-gold font-semibold">Häufigkeit:</span> nach medizinischer Empfehlung
      </p>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Prüfen Sie die Verfügbarkeit oder kontaktieren Sie uns direkt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>
</PageLayout>
