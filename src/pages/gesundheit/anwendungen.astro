---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import pageData from '@/content/pages/gesundheit-anwendungen.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>
  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Gesundheit', href: '/gesundheit' }, { label: 'Anwendungen' }]}
  />

  <!-- Back Link -->
  <section class="py-6 bg-white border-b border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6">
      <a href="/gesundheit" class="text-gold text-xs font-semibold uppercase tracking-wide hover:text-gold/80 transition-colors">← Zurück zu Gesundheit</a>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
      <p class="text-xs text-ink-muted leading-relaxed mt-6 max-w-3xl">{page.intro_body}</p>
    </div>
  </section>

  <!-- Treatment Categories Grid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Moorbäder & Moorpackungen -->
        <div class="bg-cream rounded-lg p-8">
          <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl mb-6">🌊</div>
          <h3 class="font-display font-light text-ink-dark text-[20px] mb-3">Moorbäder & Moorpackungen</h3>
          <p class="text-xs text-ink-muted leading-relaxed">Die klassische Moorbehandlung: Moorbäder, Moorpackungen und Moorumschläge für maximale Wirkung.</p>
        </div>

        <!-- Physiotherapie -->
        <div class="bg-cream rounded-lg p-8">
          <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl mb-6">🏃</div>
          <h3 class="font-display font-light text-ink-dark text-[20px] mb-3">Physiotherapie</h3>
          <p class="text-xs text-ink-muted leading-relaxed">Manuelle Therapie und Bewegungstherapie unter Anleitung erfahrener Physiotherapeuten.</p>
        </div>

        <!-- Bewegungsbad -->
        <div class="bg-cream rounded-lg p-8">
          <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl mb-6">🏊</div>
          <h3 class="font-display font-light text-ink-dark text-[20px] mb-3">Bewegungsbad</h3>
          <p class="text-xs text-ink-muted leading-relaxed">Gezieltes Training im Thermalbad, gelenkschonend und mit optimaler Wärmeunterstützung.</p>
        </div>

        <!-- Elektrotherapie -->
        <div class="bg-cream rounded-lg p-8">
          <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl mb-6">⚡</div>
          <h3 class="font-display font-light text-ink-dark text-[20px] mb-3">Elektrotherapie</h3>
          <p class="text-xs text-ink-muted leading-relaxed">Moderne Stromtherapien zur Schmerzlinderung und Muskelstimulation nach ärztlicher Verordnung.</p>
        </div>

        <!-- Inhalationen -->
        <div class="bg-cream rounded-lg p-8">
          <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl mb-6">💨</div>
          <h3 class="font-display font-light text-ink-dark text-[20px] mb-3">Inhalationen</h3>
          <p class="text-xs text-ink-muted leading-relaxed">Moorluft- und Sole-Inhalationen für Atemwege und Entspannung.</p>
        </div>

        <!-- Massagen -->
        <div class="bg-cream rounded-lg p-8">
          <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl mb-6">🧖</div>
          <h3 class="font-display font-light text-ink-dark text-[20px] mb-3">Massagen</h3>
          <p class="text-xs text-ink-muted leading-relaxed">Therapeutische Massagen zur Verspannungsabbau und Regeneration.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Medical Consultation Note -->
  <section class="py-12 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="bg-white rounded-lg p-8 border-l-4 border-gold">
        <p class="text-ink-dark font-semibold text-xs mb-2">ÄRZTLICHE BEGLEITUNG</p>
        <p class="text-xs text-ink-muted leading-relaxed">Alle Anwendungen werden von unserem erfahrenen Ärzte- und Therapeutenteam individuell abgestimmt. Zu Beginn Ihres Aufenthalts erfolgt eine ausführliche Anamnese und Untersuchung durch einen Kurarzt, um das optimale Behandlungsprogramm für Sie festzulegen.</p>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Prüfen Sie die Verfügbarkeit oder kontaktieren Sie uns direkt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>
</PageLayout>
