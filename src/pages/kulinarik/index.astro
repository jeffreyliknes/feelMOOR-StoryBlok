---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import ContentImage from '@/components/common/ContentImage.astro';
import { fetchPage } from '@/lib/storyblok';
import kulinarikFallback from '@/content/pages/kulinarik.json';

const page = (await fetchPage('kulinarik')) ?? kulinarikFallback;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Kulinarik' }]}
  />

  <!-- ── Intro Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Willkommen</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        {page.intro_image && (
          <ContentImage
            src={page.intro_image}
            alt="Restaurant und Vitalküche feelMOOR"
          />
        )}
      </div>
    </div>
  </section>

  <!-- ── Venues ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="space-y-8">
        {page.venues?.map((venue) => (
          <div class="bg-white border border-stone-light overflow-hidden">
            {venue.image && (
              <div class="aspect-[21/9] overflow-hidden">
                <img src={venue.image} alt={venue.name} loading="lazy" class="w-full h-full object-cover" />
              </div>
            )}
            <div class="grid lg:grid-cols-[1fr_280px] gap-8 lg:gap-12 p-8 lg:p-10">
              <div>
                <p class="caption-label text-gold mb-2">{venue.tagline}</p>
                <h3 class="font-display font-light text-ink-dark mb-4" style="font-size:clamp(1.4rem,2.8vw,2rem);">
                  {venue.name}
                </h3>
                {venue.note && (
                  <p class="inline-block text-xs font-medium text-gold bg-gold/10 px-3 py-1 rounded-full mb-4">{venue.note}</p>
                )}
                <p class="text-xs text-ink-muted leading-relaxed">{venue.body}</p>
                {venue.highlight && (
                  <p class="text-xs text-ink-dark font-medium mt-4">{venue.highlight}</p>
                )}
              </div>
              {venue.hours && venue.hours.length > 0 && (
                <div class="lg:border-l lg:border-stone-light lg:pl-8">
                  <p class="caption-label text-gold mb-3">Öffnungszeiten</p>
                  <ul class="space-y-1.5">
                    {venue.hours.map((h) => (
                      <li class="text-xs text-ink-muted">{h}</li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Buffet pricing ── -->
  {page.buffet_items && page.buffet_items.length > 0 && (
    <section class="py-16 lg:py-20 bg-cream border-t border-stone-light">
      <div class="max-w-2xl mx-auto px-6">
        <h2 class="font-display font-light text-ink-dark text-center mb-8" style="font-size:clamp(1.5rem,3vw,2.25rem);">{page.buffet_heading}</h2>
        <ul class="divide-y divide-stone-light/60 border-y border-stone-light/60">
          {page.buffet_items.map((item) => (
            <li class="flex items-baseline justify-between gap-4 py-3">
              <span class="text-xs text-ink-dark">{item.label}</span>
              <span class="text-xs text-gold font-medium whitespace-nowrap">{item.price}</span>
            </li>
          ))}
        </ul>
        {page.buffet_note && (
          <p class="text-xs text-ink-muted/80 leading-relaxed mt-5">{page.buffet_note}</p>
        )}
      </div>
    </section>
  )}

  <!-- ── Bottom CTA ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Tisch reservieren oder weitere Informationen erhalten.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/service-kontakt" class="btn-gold">Tisch reservieren</a>
        <a href="/oeffnungszeiten" class="btn-outline-gold">Öffnungszeiten</a>
      </div>
    </div>
  </section>

</PageLayout>
