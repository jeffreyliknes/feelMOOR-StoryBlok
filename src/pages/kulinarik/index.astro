---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import ContentImage from '@/components/common/ContentImage.astro';
import pageData from '@/content/pages/kulinarik.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'Kulinarik' }]}
  />

  <!-- ── Intro Section ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Willkommen</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        {page.intro_image && (
          <ContentImage
            src={page.intro_image}
            alt="Restaurant und Vitalküche feelMOOR"
          />
        )}
      </div>
    </div>
  </section>

  <!-- ── Highlights Grid (3 columns) ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
        {/* Vitalküche */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Vitalküche</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Nährstoffreich und leicht verdaulich, unsere Vitalküche unterstützt Ihren Körper bei der Regeneration.</p>
          <div class="mt-6 pt-6 border-t border-stone-light/50">
            <a href="/service-kontakt" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
              Mehr erfahren
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        {/* Regionale Zutaten */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Regionale Zutaten</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Direkt von Allgäuer Bauern und lokalen Partnern, Frische und Qualität garantiert.</p>
          <div class="mt-6 pt-6 border-t border-stone-light/50">
            <a href="/nachhaltigkeit" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
              Unsere Partner
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        {/* Saisonale Menüs */}
        <div class="bg-white border border-stone-light p-8 lg:p-10">
          <h3 class="font-display font-light text-ink-dark" style="font-size:clamp(1.25rem,2.5vw,1.75rem);">Saisonale Menüs</h3>
          <p class="text-xs text-ink-muted mt-4 leading-relaxed">Das Beste aus jeder Jahreszeit, von Frühling bis Winter wechseln wir kreativ die Menüs.</p>
          <div class="mt-6 pt-6 border-t border-stone-light/50">
            <a href="/service-kontakt" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
              Reservieren
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Opening Hours Note ── -->
  <section class="py-12 bg-cream border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <p class="text-xs text-ink-muted mb-4">Informationen zu unseren Öffnungszeiten erhalten Sie hier:</p>
      <a href="/oeffnungszeiten" class="inline-flex items-center gap-2 text-xs text-gold font-medium hover:gap-3 transition-all">
        Zu den Öffnungszeiten
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Bottom CTA ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Tisch reservieren oder weitere Informationen erhalten.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/service-kontakt" class="btn-gold">Tisch reservieren</a>
        <a href="/oeffnungszeiten" class="btn-outline-gold">Öffnungszeiten</a>
      </div>
    </div>
  </section>

</PageLayout>
