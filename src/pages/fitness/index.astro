---
import PageLayout from '@/layouts/PageLayout.astro';
import pageData from '@/content/pages/fitness.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>
  <!-- Hero Section -->
  <section class="relative py-24 lg:py-32 bg-forest-700 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-800 via-forest-700 to-forest-600">
      <div class="absolute inset-0 opacity-10"
           style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22/%3E%3C/svg%3E')">
      </div>
    </div>
    <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center">
      <p class="caption-label mb-4">{page.hero_caption}</p>
      <h1 class="font-display font-light text-cream" style="font-size:clamp(2.5rem,6vw,5rem);line-height:1.06;">{page.hero_heading}</h1>
      <p class="text-cream/70 text-sm max-w-xl mx-auto mt-5 leading-relaxed">{page.hero_intro}</p>
      <nav class="mt-8 flex items-center justify-center gap-2 text-xs text-cream/40">
        <a href="/" class="hover:text-cream/70 transition-colors">Start</a>
        <span>›</span>
        <span class="text-cream/60">Fitness</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-xs text-ink-muted leading-relaxed mt-6">{page.intro_body}</p>
        </div>
        <div class="bg-forest-700 rounded-lg p-8 text-center">
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-2">Für Alle Offen</p>
          <div class="text-cream text-[42px] font-display font-light leading-tight mb-4">Hotelgäste & Mitglieder</div>
          <p class="text-cream/70 text-xs leading-relaxed">Ob Sie Kurgast sind oder regionale Mitgliedschaft suchen, unser Fitnessclub bietet flexible Zugänge für jeden.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sub-page Cards -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Fitnessstudio Card -->
        <a href="/fitness/fitnessstudio" class="group bg-cream rounded-lg p-8 hover:shadow-lg transition-shadow">
          <div class="mb-6">
            <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl">🏋️</div>
          </div>
          <h3 class="font-display font-light text-ink-dark text-[24px] mb-3 group-hover:text-gold transition-colors">Fitnessstudio</h3>
          <p class="text-xs text-ink-muted leading-relaxed mb-6">Modernste Geräte und freie Gewichte, alles was Sie für ein professionelles Training brauchen.</p>
          <span class="text-gold text-xs font-semibold uppercase tracking-wide">Mehr erfahren →</span>
        </a>

        <!-- Kursprogramm Card -->
        <a href="/fitness/kurse" class="group bg-cream rounded-lg p-8 hover:shadow-lg transition-shadow">
          <div class="mb-6">
            <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl">🧘</div>
          </div>
          <h3 class="font-display font-light text-ink-dark text-[24px] mb-3 group-hover:text-gold transition-colors">Kursprogramm</h3>
          <p class="text-xs text-ink-muted leading-relaxed mb-6">Yoga, Pilates, Aquafitness und mehr, Gruppentraining für alle Fitnesslevel.</p>
          <span class="text-gold text-xs font-semibold uppercase tracking-wide">Mehr erfahren →</span>
        </a>

        <!-- Mitgliedschaften Card -->
        <a href="/fitness/mitgliedschaften" class="group bg-cream rounded-lg p-8 hover:shadow-lg transition-shadow">
          <div class="mb-6">
            <div class="w-12 h-12 bg-gold/20 rounded-full flex items-center justify-center text-gold text-xl">🎯</div>
          </div>
          <h3 class="font-display font-light text-ink-dark text-[24px] mb-3 group-hover:text-gold transition-colors">Mitgliedschaften</h3>
          <p class="text-xs text-ink-muted leading-relaxed mb-6">Flexible Tarife für Studio, Kurse und optional mit Thermenzugang, für Einheimische und Gäste.</p>
          <span class="text-gold text-xs font-semibold uppercase tracking-wide">Mehr erfahren →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Key Features Strip -->
  <section class="py-12 bg-forest-700">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div>
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-2">Feature</p>
          <p class="text-cream text-[16px] font-display font-light">Modernste Geräte</p>
        </div>
        <div>
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-2">Feature</p>
          <p class="text-cream text-[16px] font-display font-light">Professionelle Trainer</p>
        </div>
        <div>
          <p class="text-gold text-xs font-semibold uppercase tracking-wide mb-2">Feature</p>
          <p class="text-cream text-[16px] font-display font-light">Flexibler Zugang</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Prüfen Sie die Verfügbarkeit oder kontaktieren Sie uns direkt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>
</PageLayout>
