---
import PageLayout from '@/layouts/PageLayout.astro';
import pageData from '@/content/pages/jobs.json';

const page = pageData;
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <!-- ── Page Hero ── -->
  <section class="relative py-24 lg:py-32 bg-forest-700 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-800 via-forest-700 to-forest-600">
      <div class="absolute inset-0 opacity-10"
           style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22/%3E%3C/svg%3E')">
      </div>
    </div>
    <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center">
      <p class="caption-label mb-4">{page.hero_caption}</p>
      <h1 class="font-display font-light text-cream" style="font-size:clamp(2.5rem,6vw,5rem);line-height:1.06;">{page.hero_heading}</h1>
      <p class="text-cream/70 text-[14px] max-w-xl mx-auto mt-5 leading-relaxed">{page.hero_intro}</p>
      <nav class="mt-8 flex items-center justify-center gap-2 text-[11px] text-cream/40">
        <a href="/" class="hover:text-cream/70 transition-colors">Start</a>
        <span>›</span>
        <span class="text-cream/60">Karriere</span>
      </nav>
    </div>
  </section>

  <!-- ── Intro Section with Benefits ── -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="caption-label mb-4 text-gold">Karriere</p>
          <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.75rem,3.5vw,3rem);">{page.intro_heading}</h2>
          <p class="text-[13.5px] text-ink-muted mt-6 leading-relaxed">{page.intro_body}</p>
        </div>
        <div class="bg-forest-700 p-8 lg:p-12 text-cream rounded-sm flex flex-col justify-center min-h-[300px] lg:min-h-[400px]">
          <div class="space-y-6">
            <h3 class="text-[11px] tracking-widest uppercase text-gold mb-4">Warum feelMOOR?</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="text-gold mt-1">✓</span>
                <span class="text-[13.5px] text-cream/80">Arbeiten in einer einzigartigen Umgebung mit Sinn und Purpose</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-gold mt-1">✓</span>
                <span class="text-[13.5px] text-cream/80">Familiäres Team in einem wachsenden Unternehmen</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-gold mt-1">✓</span>
                <span class="text-[13.5px] text-cream/80">Weiterbildung und Entwicklungsmöglichkeiten</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-gold mt-1">✓</span>
                <span class="text-[13.5px] text-cream/80">Attraktive Konditionen und Mitarbeiterbenefits</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Open Positions Section ── -->
  <section class="py-16 lg:py-24 bg-stone-light/30">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <h2 class="font-display font-light text-ink-dark mb-6" style="font-size:clamp(1.75rem,3.5vw,3rem);">Aktuelle Stellenangebote</h2>
        <div class="bg-white border border-stone-light p-8 rounded-sm">
          <p class="text-[13.5px] text-ink-muted leading-relaxed mb-6">{page.no_open_positions_note}</p>
          <p class="text-[13.5px] text-ink-muted mb-8">Senden Sie uns Ihre aussagekräftige Bewerbung – wir überprüfen Ihre Qualifikationen gerne auf Passung.</p>
          <a href="mailto:jobs@feelmoor.de" class="btn-gold">Initiativbewerbung senden</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA (Modified) ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für eine neue Herausforderung?</h2>
      <p class="text-[13px] text-ink-muted mt-3 mb-8">Kontaktieren Sie uns mit Ihren Fragen zur Karriere im feelMOOR.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="mailto:jobs@feelmoor.de" class="btn-gold">Jetzt bewerben</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt</a>
      </div>
    </div>
  </section>

</PageLayout>
