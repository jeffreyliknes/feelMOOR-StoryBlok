---
import PageLayout from '@/layouts/PageLayout.astro';
import PackageInclusions from '@/components/packages/PackageInclusions.astro';
import PackageBookingCard from '@/components/packages/PackageBookingCard.astro';
import PackagePricing from '@/components/packages/PackagePricing.astro';
import PackageHighlights from '@/components/packages/PackageHighlights.astro';
import PackageProgram from '@/components/packages/PackageProgram.astro';
import { fetchPackages } from '@/lib/storyblok';

export async function getStaticPaths() {
  const packages = await fetchPackages();
  return packages.map((entry: any) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const pkg = entry.data;

const seoTitle = `${pkg.title}, feelMOOR Bad Wurzach`;
const seoDescription = pkg.teaser ?? `${pkg.title} im feelMOOR Gesundresort Bad Wurzach.`;

const closingParagraphs = (pkg.closing_body ?? '')
  .split(/\n\s*\n/)
  .map((p: string) => p.trim())
  .filter(Boolean);
---

<PageLayout title={seoTitle} description={seoDescription}>

  <!-- ── Top bar: back + breadcrumb ── -->
  <section class="bg-cream border-b border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <a
        href="/angebote"
        class="inline-flex items-center gap-2 text-xs font-medium tracking-wide text-ink-muted hover:text-gold transition-colors w-fit"
      >
        <svg class="w-4 h-4" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Zurück zu Angeboten
      </a>
      <nav class="flex items-center gap-2 text-xs text-ink-muted sm:justify-end">
        <a href="/" class="hover:text-gold transition-colors">Start</a>
        <span class="text-stone">/</span>
        <a href="/angebote" class="hover:text-gold transition-colors">Angebote</a>
        <span class="text-stone">/</span>
        <span class="text-ink-dark">{pkg.title}</span>
      </nav>
    </div>
  </section>

  <!-- ── Title section ── -->
  <section class="bg-cream pt-8 pb-6 lg:pt-10 lg:pb-8">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
        <div class="max-w-3xl">
          {pkg.tag && (
            <p class="caption-label mb-2">{pkg.tag}</p>
          )}
          <h1 class="font-display font-light text-ink-dark tracking-tight text-[clamp(1.85rem,4vw,3rem)] leading-[1.08]">
            {pkg.title}
          </h1>
          {pkg.subtitle && (
            <p class="mt-3 font-display font-light text-ink-muted text-lg lg:text-xl leading-snug">{pkg.subtitle}</p>
          )}
          <p class="mt-3 text-xs text-ink-muted flex flex-wrap items-center gap-x-2 gap-y-1">
            {pkg.nights && (
              <>
                <span>{pkg.nights}</span>
                {pkg.price_from && <span class="text-stone hidden sm:inline">·</span>}
              </>
            )}
            {pkg.price_from && (
              <span class="text-gold font-medium">ab {pkg.price_from} €</span>
            )}
          </p>
        </div>
        <div class="flex flex-wrap gap-3 lg:pt-7 flex-shrink-0">
          {pkg.booking_options && pkg.booking_options.length > 0 ? (
            pkg.booking_options.map((opt) => (
              <a href={opt.href} target="_blank" rel="noopener" class="btn-gold flex-col items-center text-center gap-0.5 py-2.5">
                <span class="text-[0.65rem] uppercase tracking-wider opacity-70 font-sans">{opt.label}</span>
                <span class="text-xs">Verfügbarkeit prüfen</span>
              </a>
            ))
          ) : pkg.booking_link ? (
            <a href={pkg.booking_link} class="btn-gold">
              Jetzt buchen
              <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none">
                <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          ) : (
            <a href="#booking" class="btn-gold">
              Verfügbarkeit prüfen
              <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none">
                <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
          <a href="/service-kontakt" class="btn-outline-gold">Anfrage</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Hero image ── -->
  {pkg.image && (
    <section class="bg-cream pb-10 lg:pb-14">
      <div class="max-w-screen-xl mx-auto px-6">
        <img
          src={pkg.image}
          alt={pkg.image_alt ?? pkg.title}
          class="w-full aspect-video object-cover rounded-xl"
          loading="eager"
        />
      </div>
    </section>
  )}

  <!-- ── Content section: two-column layout ── -->
  <section class="py-10 lg:py-16 bg-cream">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid lg:grid-cols-[1fr_350px] gap-8 lg:gap-12">

        <!-- Left column: article body + inclusions + recommendations -->
        <div class="space-y-10">
          <article class="article-prose max-w-none" set:html={pkg.body_html}>
          </article>

          <PackageInclusions items={pkg.includes} note={pkg.inclusion_note} />

          <PackageInclusions items={pkg.recommendations} heading="Unsere Empfehlung" />

          {pkg.availability && (
            <div class="rounded-xl border border-stone-light bg-white p-6">
              <p class="caption-label text-gold mb-2">Termine</p>
              <p class="text-xs text-ink-muted leading-relaxed">{pkg.availability}</p>
              {pkg.availability_note && (
                <p class="text-xs text-ink-muted/80 leading-relaxed mt-2">{pkg.availability_note}</p>
              )}
            </div>
          )}
        </div>

        <!-- Right column: sticky booking card -->
        <div class="lg:col-start-2">
          <PackageBookingCard
            nights={pkg.nights}
            priceFrom={pkg.price_from}
            priceLabel={pkg.price_label}
            includes={pkg.includes}
            bookingOptions={pkg.booking_options}
            bookingLink={pkg.booking_link}
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ── Pricing tiers ── -->
  <PackagePricing tiers={pkg.pricing_tiers} />

  <!-- ── Feature highlights ── -->
  <PackageHighlights highlights={pkg.highlights} />

  <!-- ── Program / Punktekatalog ── -->
  <PackageProgram
    intro={pkg.program_intro}
    pointsCatalog={pkg.points_catalog}
    columns={pkg.program_columns}
    rows={pkg.program_rows}
  />

  <!-- ── Gallery ── -->
  {pkg.gallery && pkg.gallery.length > 0 && (
    <section class="py-12 lg:py-16 bg-white border-t border-stone-light">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {pkg.gallery.map((img) => (
            <img
              src={img.image}
              alt={img.alt || pkg.title}
              class="w-full aspect-[4/3] object-cover rounded-xl"
              loading="lazy"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Closing philosophy ── -->
  {(pkg.closing_heading || closingParagraphs.length > 0) && (
    <section class="py-16 lg:py-20 bg-cream border-t border-stone-light">
      <div class="max-w-3xl mx-auto px-6">
        {pkg.closing_heading && (
          <h2 class="font-display font-light text-ink-dark text-2xl lg:text-3xl mb-6">{pkg.closing_heading}</h2>
        )}
        <div class="space-y-4">
          {closingParagraphs.map((para) => (
            <p class="text-xs text-ink-muted leading-relaxed">{para}</p>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Bottom CTA ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Prüfen Sie die Verfügbarkeit oder kontaktieren Sie uns direkt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>

</PageLayout>
