---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import { getStory, getStories } from '@/lib/storyblok';

let posts: any[] = [];
try {
  posts = (await getStories('blog/', Astro)).sort(
    (a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
} catch {
  // blog folder not yet populated
}

const page = await getStory('pages/news', Astro);
---

<PageLayout title={page.seo_title} description={page.seo_description}>

  <PageHero
    image={page.hero_image}
    imageAlt={page.hero_image_alt}
    caption={page.hero_caption}
    heading={page.hero_heading}
    intro={page.hero_intro}
    breadcrumb={[{ label: 'Start', href: '/' }, { label: 'News' }]}
  />

  <!-- ── Blog posts section ── -->
  {posts.length > 0 ? (
    <section class="py-20 lg:py-28 bg-cream">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="group bg-white border border-stone-light rounded-xl overflow-hidden hover:border-gold/30 transition-colors duration-300 flex flex-col">

              <!-- Blog Image -->
              <div class="relative overflow-hidden bg-stone-light/50 aspect-[4/3]">
                {post.data.image ? (
                  <img
                    src={post.data.image}
                    alt={post.data.image_alt ?? post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-stone-light to-stone-light/70 flex items-center justify-center">
                    <svg class="w-12 h-12 text-stone/30" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  </div>
                )}
              </div>

              <!-- Blog Content -->
              <div class="p-6 lg:p-7 flex flex-col flex-grow">
                <!-- Date & Category -->
                <div class="flex items-center gap-3 text-xs text-ink-muted mb-3 pb-3 border-b border-stone-light/60">
                  {post.data.date && (
                    <time datetime={post.data.date}>
                      {new Date(post.data.date).toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  )}
                  {post.data.date && post.data.category && <span class="text-stone">·</span>}
                  {post.data.category && (
                    <span class="text-gold font-medium">{post.data.category}</span>
                  )}
                </div>

                <!-- Title -->
                <h3 class="font-display font-light text-ink-dark text-xl lg:text-2xl leading-tight mb-3">
                  {post.data.title}
                </h3>

                <!-- Teaser -->
                {post.data.teaser && (
                  <p class="text-xs text-ink-muted leading-relaxed mb-5 flex-grow">
                    {post.data.teaser}
                  </p>
                )}

                <!-- Read more link -->
                <div class="pt-4 border-t border-stone-light/60">
                  <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-2 text-xs font-medium text-ink-dark hover:text-gold transition-colors">
                    Weiterlesen
                    <svg class="w-4 h-4" viewBox="0 0 14 14" fill="none">
                      <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </div>

            </article>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <section class="py-20 lg:py-28 bg-cream">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="flex flex-col items-center justify-center gap-6 text-center py-12 lg:py-20">
          <div class="w-16 h-16 rounded-full bg-stone-light/50 flex items-center justify-center">
            <svg class="w-8 h-8 text-stone/30" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <div>
            <h2 class="font-display font-light text-ink-dark text-2xl mb-2">News folgen in Kürze</h2>
            <p class="text-xs text-ink-muted max-w-md">
              Wir arbeiten an spannenden Inhalten. Schauen Sie bald wieder vorbei für Neuigkeiten, Berichte und Tipps aus dem feelMOOR.
            </p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── Bottom CTA ── -->
  <section class="py-16 bg-white border-t border-stone-light">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h2 class="font-display font-light text-ink-dark" style="font-size:clamp(1.5rem,3vw,2.5rem);">Bereit für Ihren Aufenthalt?</h2>
      <p class="text-xs text-ink-muted mt-3 mb-8">Prüfen Sie die Verfügbarkeit oder kontaktieren Sie uns direkt.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#booking" class="btn-gold">Jetzt buchen</a>
        <a href="/service-kontakt" class="btn-outline-gold">Kontakt & Anfrage</a>
      </div>
    </div>
  </section>

</PageLayout>
