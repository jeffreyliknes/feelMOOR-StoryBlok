---
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import BookingWidget from '@/components/common/BookingWidget.astro';
import SEO from '@/components/common/SEO.astro';
import Favicons from '@/components/common/Favicons.astro';
import '@/styles/global.css';
import '@/styles/booking-widget.css';

const inEditor = Astro.url.searchParams.has('_storyblok');

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  heroOffset?: boolean; // true = first section starts under fixed header
  htmlLang?: 'de' | 'en';
  locale?: 'de' | 'en';
}

const {
  title,
  description,
  ogImage,
  noindex,
  heroOffset = true,
  htmlLang = 'de',
  locale = 'de',
} = Astro.props;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Favicons />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <SEO {title} {description} {ogImage} {noindex} locale={locale} />

    <!-- Booking widget CDN CSS -->
    <link rel="stylesheet" href="https://mws-booking-widget.ams3.cdn.digitaloceanspaces.com/mws-booking-widget-v1.min.css" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header locale={locale} />

    <main class={heroOffset ? 'pt-[var(--header-h)]' : ''} style="flex: 1;">
      <slot />
    </main>

    <Footer locale={locale} />
    <BookingWidget />

    {inEditor && (
      <script src="https://app.storyblok.com/f/storyblok-v2-latest.js" is:inline></script>
    )}
    {inEditor && (
      <script is:inline>
        // Storyblok visual editor bridge: reload the iframe when content changes.
        window.addEventListener('load', function () {
          var bridge = new window.StoryblokBridge();
          bridge.on(['input', 'published', 'change'], function (event) {
            if (event.action === 'input') return; // reload on save/publish only
            window.location.reload();
          });
        });
      </script>
    )}
  </body>
</html>
